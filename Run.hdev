<par name="ParmDict" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="ResourceDictHandle" base_type="ctrl" dimension="0"/>
<par name="JSONData" base_type="ctrl" dimension="0"/>
<par name="Ex" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<c></c>
<l>try  </l>
<l>    json_to_dict (ParmDict, [], [], G_ParmDict)</l>
<l>*     Init_Chipping (ChippingHandle)</l>
<c>    </c>
<l>*     Init_HalconClass ('Class', G_ParmDict, HalconClassHandle)</l>
<c></c>
<l>    create_dict (ResourceDictHandle)</l>
<l>*     set_dict_tuple (ResourceDictHandle, 'HalconClassHandle', HalconClassHandle)</l>
<l>*     set_dict_tuple (ResourceDictHandle, 'ChippingHandle', ChippingHandle)</l>
<l>*     dict_to_json (G_ParmDict, [], [], JSONData)</l>
