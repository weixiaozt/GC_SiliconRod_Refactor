<procedure name="Log">
<interface>
<ic>
<par name="Tags" base_type="ctrl" dimension="0"/>
<par name="Values" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<c></c>
<l>try</l>
<l> get_system_time (MSecond, Second, Minute, Hour, Day, YDay, Month, Year)</l>
<l> DateToday := Year + '.'+ Month + '.' + Day</l>
<l> Dir := './log/'+DateToday+'/'</l>
<l> FileName:='check'</l>
<l> file_exists (Dir +  FileName, FileExists)</l>
<l> if (FileExists=0)</l>
<l>     file_exists (Dir, DirExsists)</l>
<l>     if (DirExsists=0)</l>
<l>         tuple_split (Dir, '/', SubDir)</l>
<l>         CurrentDir := ''</l>
<l>         for i := 0 to |SubDir|-1 by 1</l>
<l>             CurrentDir := CurrentDir+SubDir[i]+'/'</l>
<l>             file_exists (CurrentDir, FileExists)</l>
<l>             if (FileExists=0)</l>
<l>                 make_dir (CurrentDir)</l>
<l>             endif</l>
<l>         endfor</l>
<l>     endif</l>
<l> endif</l>
<c> </c>
<c> </c>
<l>  open_file (Dir + FileName, 'append', FileHandle)</l>
<l>  fwrite_string (FileHandle, Hour*10000000+Minute*100000+Second*1000+MSecond+'\t')</l>
<l>  FileString := Tags+'\t'+Values</l>
<l>  fwrite_string (FileHandle, FileString)</l>
<l>  fnew_line (FileHandle)</l>
<c> </c>
<l>  close_file (FileHandle)</l>
<l>catch (Exception)</l>
<l>    try</l>
<l>        close_file (FileHandle)</l>
<l>    catch (Exception)</l>
<l>    endtry</l>
<c></c>
<l>endtry</l>
<l>return ()</l>
</body>
<docu id="Log">
<parameters>
<parameter id="Tags"/>
<parameter id="Values"/>
</parameters>
</docu>
</procedure>
<procedure name="Ai_Clase_Region_Chipping_COPY_1">
<interface>
<io>
<par name="Cell" base_type="iconic" dimension="0"/>
<par name="ConnectedRegions" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="G_ParmDict" base_type="ctrl" dimension="0"/>
<par name="RegionDictHandle" base_type="ctrl" dimension="0"/>
<par name="ObjectNumberLimit" base_type="ctrl" dimension="0"/>
<par name="DLPreprocessParam" base_type="ctrl" dimension="0"/>
<par name="DLModelHandle" base_type="ctrl" dimension="0"/>
<par name="SelectName" base_type="ctrl" dimension="0"/>
<par name="MAX_SIZE" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>try</l>
<l>    count_obj (ConnectedRegions, Number)</l>
<l>    gen_empty_obj (ImageBatch)</l>
<l>    if (Number&gt;ObjectNumberLimit)</l>
<l>        Number := ObjectNumberLimit</l>
<l>    endif</l>
<l>    for n := 1 to Number by 1</l>
<l>        select_obj (ConnectedRegions, ObjectSelected, n)</l>
<l>        region_features (ObjectSelected, 'outer_radius', outer_radiusValue)</l>
<l>        shape_trans (ObjectSelected, RegionTrans1, 'outer_circle')</l>
<l>        if (MAX_SIZE&gt;outer_radiusValue)</l>
<l>            try</l>
<l>                dilation_circle (RegionTrans1, RegionTrans1, MAX_SIZE-outer_radiusValue)</l>
<l>            catch (Exception)</l>
<l>            endtry</l>
<l>        endif</l>
<l>        shape_trans (RegionTrans1, RegionTrans2, 'rectangle1')</l>
<l>        reduce_domain (Cell, RegionTrans2, ImageReduced)</l>
<l>        crop_domain (ImageReduced, ImagePart)</l>
<l>        concat_obj (ImageBatch, ImagePart, ImageBatch)</l>
<l>    endfor</l>
<c></c>
<c></c>
<c></c>
<l>    count_obj (ImageBatch, BatchSizeInference)</l>
<l>gen_dl_samples_from_images (ImageBatch, DLSampleBatch)</l>
<l>preprocess_dl_samples (DLSampleBatch, DLPreprocessParam)</l>
<l>    apply_dl_model (DLModelHandle, DLSampleBatch, [], DLResultBatch)</l>
<l>    for Index := 0 to BatchSizeInference-1 by 1</l>
<l>        get_dict_tuple (DLResultBatch[Index], 'classification_class_names', class_names)</l>
<l>        LoadParam (G_ParmDict, 'AI', '软件设置', '开启AI分类调试', 'FALSE', 2, 'bool', '', classF)</l>
<l>        if (classF!='FALSE')</l>
<l>            try</l>
<l>                get_system_time (MSecond, Second, Minute, Hour, Day, YDay, Month, Year)</l>
<l>                IDTime := Hour*100000+Minute*100000+Second*1000+MSecond</l>
<l>SaveImage (ImagePart, './algorithm/debugImage/'+class_names[0], 'bmp', IDTime)</l>
<l>            catch (Exception)</l>
<l>            endtry</l>
<l>        endif</l>
<l>        tuple_find (SelectName, class_names[0], Indices)</l>
<l>        if (Indices!=-1)</l>
<l>            select_obj (ConnectedRegions, SelectedObject, Index+1)</l>
<l>            try</l>
<l>                get_dict_object (OutObject, RegionDictHandle, class_names[0])</l>
<l>            catch (Exception)</l>
<l>                gen_empty_obj (OutObject)</l>
<l>            endtry</l>
<l>            union2 (OutObject, SelectedObject, RegionUnion)</l>
<l>            set_dict_object (RegionUnion, RegionDictHandle, class_names[0])</l>
<l>        endif</l>
<c></c>
<l>    endfor</l>
<l>catch (Exception)</l>
<c></c>
<l>endtry</l>
<l>return ()</l>
</body>
<docu id="Ai_Clase_Region_Chipping_COPY_1">
<parameters>
<parameter id="Cell"/>
<parameter id="ConnectedRegions"/>
<parameter id="DLModelHandle"/>
<parameter id="DLPreprocessParam"/>
<parameter id="G_ParmDict"/>
<parameter id="MAX_SIZE"/>
<parameter id="ObjectNumberLimit"/>
<parameter id="RegionDictHandle"/>
<parameter id="SelectName"/>
</parameters>
</docu>
</procedure>
<procedure name="SaveImage">
<interface>
<io>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="path" base_type="ctrl" dimension="0"/>
<par name="imgformat" base_type="ctrl" dimension="0"/>
<par name="ID" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>tuple_split (path, '/\\', Substrings)</l>
<l>file_exists (path, Exists)</l>
<l>pth := Substrings[0]</l>
<l>if (not Exists)</l>
<l>    for i := 1 to |Substrings|-2 by 1</l>
<l>        pth := pth + '/'+ Substrings[i]</l>
<l>        file_exists (pth, Exist)</l>
<l>        if (not Exist)</l>
<l>            make_dir (pth)</l>
<l>        endif</l>
<l>    endfor</l>
<l>endif</l>
<l>FileName := path + ID</l>
<l>try</l>
<c></c>
<l>    write_image (Image, imgformat, 0, FileName)</l>
<c></c>
<c></c>
<l>catch (Exception)</l>
<l>endtry</l>
<l>return ()</l>
</body>
<docu id="SaveImage">
<parameters>
<parameter id="ID">
<default_type>integer</default_type>
<default_value>20191001083059999</default_value>
<description lang="zh_CN">对应数据库主键ID</description>
<mixed_type>false</mixed_type>
<sem_type>integer</sem_type>
<type_list>
<item>integer</item>
</type_list>
<value_max>301910010830999</value_max>
<value_min>201910010830999</value_min>
</parameter>
<parameter id="Image">
<description lang="zh_CN">要存的图片，如果多相机请将其做成图像数组存入其中</description>
</parameter>
<parameter id="imgformat">
<default_type>string</default_type>
<default_value>'bmp'</default_value>
<description lang="zh_CN">图片的存图格式</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<type_list>
<item>string</item>
</type_list>
<value_list>
<item>'tiff'</item>
<item>'tiff mask'</item>
<item>'tiff alpha'</item>
<item>'tiff deflate 9'</item>
<item>'tiff deflate 9 alpha'</item>
<item>'tiff jpeg 90'</item>
<item>'tiff lzw'</item>
<item>'tiff lzw alpha '</item>
<item>'tiff packbits'</item>
<item>'bigtiff'</item>
<item>'bigtiff mask'</item>
<item>'bigtiff alpha'</item>
<item>'bigtiff deflate 9'</item>
<item>'bigtiff deflate 9 alpha'</item>
<item>'bigtiff jpeg 90'</item>
<item>'bigtiff lzw'</item>
<item>'bigtiff lzw alpha '</item>
<item>'bigtiff packbits'</item>
<item>'bmp'</item>
<item>'jpeg'</item>
<item>'jpeg 100'</item>
<item>'jpeg 80'</item>
<item>'jpeg 60'</item>
<item>'jpeg 40'</item>
<item>'jpeg 20'</item>
<item>'jp2'</item>
<item>'jp2 50'</item>
<item>'jp2 40'</item>
<item>'jp2 30'</item>
<item>'jp2 20'</item>
<item>'jpegxr'</item>
<item>'jpegxr 50'</item>
<item>'jpegxr 40'</item>
<item>'jpegxr 30'</item>
<item>'jpegxr 20'</item>
<item>'png'</item>
<item>'png best'</item>
<item>'png fastest'</item>
<item>'png none'</item>
<item>'ima'</item>
<item>'hobj'</item>
</value_list>
</parameter>
<parameter id="path">
<default_type>string</default_type>
<default_value>'./image'</default_value>
<description lang="zh_CN">图片存储路径</description>
<mixed_type>false</mixed_type>
<sem_type>filename.dir</sem_type>
<type_list>
<item>string</item>
</type_list>
