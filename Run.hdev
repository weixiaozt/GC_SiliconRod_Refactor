<procedure name="CraeteResultDicts">
<interface>
<ic>
<par name="JBChrt" base_type="ctrl" dimension="0"/>
<par name="GGChrt" base_type="ctrl" dimension="0"/>
<par name="DJHeadBack" base_type="ctrl" dimension="0"/>
<par name="JXHeadBack" base_type="ctrl" dimension="0"/>
<par name="InciseLeth" base_type="ctrl" dimension="0"/>
<par name="SW" base_type="ctrl" dimension="0"/>
<par name="MaxD" base_type="ctrl" dimension="0"/>
<par name="MinD" base_type="ctrl" dimension="0"/>
<par name="start" base_type="ctrl" dimension="0"/>
<par name="endIncise" base_type="ctrl" dimension="0"/>
<par name="KX_LocationXStart" base_type="ctrl" dimension="0"/>
<par name="LJ_Tuple" base_type="ctrl" dimension="0"/>
<par name="HeadBack_Tuple" base_type="ctrl" dimension="0"/>
<par name="QX" base_type="ctrl" dimension="0"/>
<par name="Coordinate" base_type="ctrl" dimension="0"/>
<par name="Weight" base_type="ctrl" dimension="0"/>
<par name="Value" base_type="ctrl" dimension="0"/>
<par name="Value1" base_type="ctrl" dimension="0"/>
<par name="Value2" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="ResultDict" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>create_dict (ResultDict)</l>
<l>ID := JBChrt+'-'+GGChrt</l>
<l>set_dict_tuple (ResultDict, '晶编', ID)</l>
<l>set_dict_tuple (ResultDict, '规格号', GGChrt)</l>
<l>set_dict_tuple (ResultDict, '等径长', int(DJHeadBack))</l>
<l>set_dict_tuple (ResultDict, '应力长', int(InciseLeth))</l>
<l>if (JXHeadBack&lt;int(InciseLeth))</l>
<l>    JXHeadBack := int(DJHeadBack)-45</l>
<l>endif</l>
<l>set_dict_tuple (ResultDict, '晶线长', JXHeadBack)</l>
<l>set_dict_tuple (ResultDict, '收尾方式', SW)</l>
<l>set_dict_tuple (ResultDict, '直径Max', int(MaxD))</l>
<l>set_dict_tuple (ResultDict, '直径Min', int(MinD))</l>
<l>if (int(JXHeadBack)&gt;int(DJHeadBack))</l>
<l>    JXHeadBack := DJHeadBack</l>
<l>endif</l>
<l>set_dict_tuple (ResultDict, '鼓棱长度', int(JXHeadBack))</l>
<l>set_dict_tuple (ResultDict, '等径长度', int(DJHeadBack))</l>
<l>set_dict_tuple (ResultDict, '重量', Weight)</l>
<l>TT := [KX_LocationXStart,0]</l>
<l>tuple_sort (TT, Sorted)</l>
<l>tuple_mean ([MaxD,MinD], Mean)</l>
<l>* set_dict_tuple (ResultDict, '头反', abs(start-Sorted[0]))</l>
<l>set_dict_tuple (ResultDict, '头反', HeadBack_Tuple)</l>
<l>set_dict_tuple (ResultDict, '尾反', abs(DJHeadBack-InciseLeth))</l>
<l>set_dict_tuple (ResultDict, '头转肩坐标', start)</l>
<l>set_dict_tuple (ResultDict, '头反坐标', (start+HeadBack_Tuple))</l>
<l>set_dict_tuple (ResultDict, '尾反坐标', Sorted[1])</l>
<l>set_dict_tuple (ResultDict, '孪晶', LJ_Tuple)</l>
<l>set_dict_tuple (ResultDict, '可获得', 0)</l>
<l>set_dict_tuple (ResultDict, '头部直径', int(Mean))</l>
<l>set_dict_tuple (ResultDict, '中部直径', int(Mean))</l>
<l>set_dict_tuple (ResultDict, '尾部直径', int(Mean))</l>
<l>for Index := 0 to |Coordinate|-1 by 1</l>
<l>    c := '划线段长'+(Index+1)</l>
<l>    set_dict_tuple (ResultDict, c, Coordinate[Index])</l>
<l>endfor</l>
<c></c>
<l>set_dict_tuple (ResultDict, '异常区域1', 0)</l>
<c></c>
<l>return ()</l>
</body>
<docu id="CraeteResultDicts">
<parameters>
<parameter id="Coordinate"/>
<parameter id="DJHeadBack"/>
<parameter id="GGChrt"/>
<parameter id="HeadBack_Tuple"/>
<parameter id="InciseLeth"/>
<parameter id="JBChrt"/>
<parameter id="JXHeadBack"/>
<parameter id="KX_LocationXStart"/>
<parameter id="LJ_Tuple"/>
<parameter id="MaxD"/>
<parameter id="MinD"/>
<parameter id="QX"/>
<parameter id="ResultDict"/>
<parameter id="SW"/>
<parameter id="Value"/>
<parameter id="Value1"/>
<parameter id="Value2"/>
<parameter id="Weight"/>
<parameter id="endIncise"/>
<parameter id="start"/>
</parameters>
</docu>
</procedure>
<procedure name="End_Check">
<interface>
<ic>
<par name="XC" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>global tuple QuitTaskFlag</l>
<l>modbus_write_registerFloat ()</l>
<l>modbus_write_bit (0, 126, 1)</l>
<l>EnQueueLog ('Log', '126', '写', '1')</l>
<l>modbus_write_bit (0, 176, 1)</l>
<l>while (QuitTaskFlag=0)</l>
<l>Read_Modbus ('bool', 176, 1, DS)</l>
<l>Read_Modbus ('bool', 126, 1, Dd)</l>
<c></c>
<l>Read_JT_COPY_1 (JT)</l>
<l>    if (JT=2)</l>
<l>WAIT_FW (JT)</l>
<l>        modbus_write_bit (0, 126, 1)</l>
<l>    endif</l>
<c></c>
<l>    if (DS=0and Dd=0)</l>
<l>*         wait_seconds (10)</l>
<l>EnQueueLog ('Log', '下降检测顶升', '', '')</l>
<l>        break</l>
<l>    endif</l>
<l>endwhile</l>
<c></c>
<c></c>
<l>return ()</l>
</body>
<docu id="End_Check">
<parameters>
<parameter id="XC"/>
</parameters>
</docu>
</procedure>
<procedure name="Laser_Engraved">
<interface>
<io>
<par name="EmptyObjectT" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="KX_LocationXStart" base_type="ctrl" dimension="0"/>
<par name="KX_Location1Start" base_type="ctrl" dimension="0"/>
<par name="KX_Location2Start" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="JT" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>global tuple QuitTaskFlag</l>
<l>modbus_write_registerFloat ()</l>
<l>* modbus_write_registerFloat ()</l>
<l>modbus_write_bit (0, 126, 1)</l>
<l>while (QuitTaskFlag=0)</l>
<l>Read_JT (JT)</l>
<l>    if (JT=2)</l>
<l>        return ()</l>
<l>    endif</l>
<l>Read_Modbus ('bool', 126, 1, YD)</l>
<l>    if (YD=0)</l>
<l>        break</l>
<l>    endif</l>
<l>endwhile</l>
<c></c>
<l>modbus_write_registerFloat ()</l>
<l>* Read_Modbus ('float', 720, 2, YD)</l>
<c></c>
<l>modbus_write_bit (0, 720, 1)</l>
<l>while (QuitTaskFlag=0)</l>
<l>Read_JT (JT)</l>
<l>    if (JT=2)</l>
<l>        return ()</l>
<l>    endif</l>
<l>Read_Modbus ('bool', 720, 1, YD)</l>
<l>    if (YD=0)</l>
<l>        break</l>
<l>    endif</l>
<l>endwhile</l>
<c></c>
<l>while (QuitTaskFlag=0)</l>
<c></c>
<l>Read_Modbus ('bool', 176, 1, XJ)</l>
<l>    if (XJ=0)</l>
<l>        break</l>
<l>    endif</l>
<l>endwhile</l>
<c></c>
<c></c>
<l>modbus_write_bit (0, 233, 1)</l>
<l>modbus_write_bit (0, 230, 1)</l>
<l>count_seconds (Seconds)</l>
<c></c>
<l>count_seconds (Seconds1)</l>
<c></c>
<l>wait_seconds (12)</l>
<c></c>
<l>* wait_seconds (12)</l>
<l>* modbus_write_registerFloat ()</l>
<l>* modbus_write_bit (0, 720, 1)</l>
<l>* while (QuitTaskFlag=0)</l>
<l>* Read_JT (JT)</l>
<l>*     if (JT=2)</l>
<l>*         return ()</l>
<l>*     endif</l>
<l>* Read_Modbus ('bool', 720, 1, YD)</l>
<l>*     if (YD=0)</l>
<l>*         break</l>
<l>*     endif</l>
<l>* endwhile</l>
<l>* modbus_write_bit (0, 233, 1)</l>
<l>* modbus_write_bit (0, 230, 1)</l>
<l>* wait_seconds (12)</l>
<l>return ()</l>
</body>
<docu id="Laser_Engraved">
<parameters>
<parameter id="EmptyObjectT"/>
<parameter id="JT"/>
<parameter id="KX_Location1Start"/>
<parameter id="KX_Location2Start"/>
<parameter id="KX_LocationXStart"/>
</parameters>
</docu>
</procedure>
<procedure name="Call_PLC_Can_Read_MysqlTp">
<interface>
<ic>
<par name="ID_Tuple" base_type="ctrl" dimension="0"/>
<par name="ID" base_type="ctrl" dimension="0"/>
<par name="SHOUDONGTuple" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="An_exception_is_reported" base_type="ctrl" dimension="0"/>
<par name="ex" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>global tuple QuitTaskFlag</l>
<l>count_seconds (Seconds)</l>
<l>ex := 0</l>
<c>* ********晶编写入多恩多核对寄存器************************************</c>
<l>* for Index := 0 to 22 by 1</l>
<l>*     modbus_write_register (0, 2170+Index, ID_Tuple[Index])</l>
<l>* endfor</l>
<l>* modbus_write_register (0, 2200, 1)</l>
<l>An_exception_is_reported := '正常'</l>
<c>* ******************************************************************</c>
<l>if (SHOUDONGTuple=0)</l>
<l>    while (QuitTaskFlag=0)</l>
<c></c>
<l>Read_Modbus ('int', 2300, 1, Tuple)</l>
<l>        if (Tuple=1 or Tuple=2)</l>
<l>            modbus_write_register (0, 2200, 0)</l>
<l>EnQueueLog ('Log', 'PLC接收自动数据正常', 2300, 1)</l>
<l>            break</l>
<l>        elseif (Tuple=3 or Tuple=4)</l>
<l>            if (Tuple=3)</l>
<l>*                 modbus_write_register (0, 3502, 1)</l>
<l>                wait_seconds (1)</l>
<l>*                 open_window (250, 500, 500, 500, 0, 'visible', '', WindowHandle)</l>
<l>*                 disp_text (WindowHandle, '检测到孪晶，请及时处理！！！', 'window', 200, 150, 'black', [], [])</l>
<l>                while (1)</l>
<l>Read_Modbus ('int', 2600, 1, Tuple)</l>
<l>                    if (Tuple=2)</l>
<l>*                         close_window (WindowHandle)</l>
<l>                        break</l>
<l>                    endif</l>
<l>                endwhile</l>
<l>            endif</l>
<l>            An_exception_is_reported := '错误'</l>
<l>*             modbus_write_register (0, 3654, 1)</l>
<l>            modbus_write_register (0, 2200, 0)</l>
<l>EnQueueLog_COPY_1 ('Log', 'PLC接收自动数据异常', 2300, Tuple)</l>
<l>            break</l>
<l>        else</l>
<c></c>
<l>* Read_Modbus ('int', 2102, 1, Tuple)</l>
<c></c>
<c></c>
<l>            count_seconds (Seconds1)</l>
<l>            t := Seconds1-Seconds</l>
<l>            if (t&gt;8)</l>
<l>                modbus_write_register (0, 2200, 0)</l>
<l>                wait_seconds (1)</l>
<l>                modbus_write_register (0, 2200, 1)</l>
<l>                ex := 1</l>
<l>                return ()</l>
<l>            endif</l>
<c></c>
<c></c>
<c></c>
<l>        endif</l>
<l>    endwhile</l>
<l>elseif (SHOUDONGTuple=1)</l>
<l>    while (QuitTaskFlag=0)</l>
<l>Read_Modbus ('int', 2300, 1, Tuple)</l>
<l>        if (Tuple=1 or Tuple=2)</l>
<l>            modbus_write_register (0, 2200, 0)</l>
<l>EnQueueLog ('Log', 'PLC接收手动数据正常', 2300, 1)</l>
<l>            break</l>
<l>        elseif (Tuple=3 or Tuple=4)</l>
<l>            An_exception_is_reported := '错误'</l>
<l>            modbus_write_register (0, 2200, 0)</l>
<l>EnQueueLog ('Log', 'PLC接收手动数据异常', 2300, Tuple)</l>
<l>            break</l>
<l>        endif</l>
<l>    endwhile</l>
<l>endif</l>
<l>while (QuitTaskFlag=0)</l>
<l>Read_Modbus ('bool', 126, 1, YD)</l>
<l>    if (YD=0)</l>
<l>        break</l>
<l>    endif</l>
<l>endwhile</l>
<l>Read_Modbus ('bool', 1024, 1, SD)</l>
<l>if (SD=1)</l>
<l>    modbus_write_bit (0, 1024, 0)</l>
<l>EnQueueLog_COPY_1 ('Log', '检测中收到手动触发', '手动信号清零', '')</l>
<l>endif</l>
<c></c>
<l>return ()</l>
</body>
<docu id="Call_PLC_Can_Read_MysqlTp">
<parameters>
<parameter id="An_exception_is_reported"/>
<parameter id="ID"/>
<parameter id="ID_Tuple"/>
<parameter id="SHOUDONGTuple"/>
<parameter id="ex"/>
</parameters>
</docu>
</procedure>
<procedure name="Send_Mysql">
<interface>
<io>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<oo>
<par name="ImageDUMP" base_type="iconic" dimension="0"/>
</oo>
</interface>
<body>
<c></c>
<c></c>
<c></c>
<l>concat_obj (UPTakePhotoOut, yinlieImage, UPTakePhotoOut)</l>
<l>concat_obj (UPTakePhotoOut, yinliImage, UPTakePhotoOut)</l>
<l>concat_obj (UPTakePhotoOut, DownTakePhoto, UPTakePhotoOut)</l>
<l>* concat_obj (UPTakePhotoOut, LJTakePhoto, UPTakePhotoOut)</l>
<l>list_files ('D:/imageA', ['files','follow_links','recursive'], ImageFiles)</l>
<l>tuple_regexp_select (ImageFiles, ['\\.(hobj)$','ignore_case'], ImageFiles)</l>
<l>try</l>
<l>    if (ImageFiles&gt;300)</l>
<l>        delete_file (ImageFiles[0])</l>
<l>    endif</l>
<l>catch (Exception)</l>
<l>endtry</l>
<l>try</l>
<l>    write_object (UPTakePhotoOut, 'D:/DEBUGImage/'+ID)</l>
<l>catch (Exception)</l>
<l>endtry</l>
<l>return ()</l>
</body>
<docu id="Send_Mysql">
<parameters>
<parameter id="Image"/>
<parameter id="ImageDUMP"/>
</parameters>
</docu>
</procedure>
<procedure name="SaveImage_COPY_1">
<interface>
<io>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="path" base_type="ctrl" dimension="0"/>
<par name="imgformat" base_type="ctrl" dimension="0"/>
<par name="ID" base_type="ctrl" dimension="0"/>
<par name="WaferID" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="FileNameSQL" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>tuple_split (path, '/\\', Substrings)</l>
<l>file_exists (path, Exists)</l>
<l>pth := Substrings[0]</l>
<l>if (not Exists)</l>
<l>    for i := 1 to |Substrings|-1 by 1</l>
<l>        pth := pth + '/'+ Substrings[i]</l>
<l>        file_exists (pth, Exist)</l>
<l>        if (not Exist)</l>
<l>            make_dir (pth)</l>
<l>        endif</l>
<l>    endfor</l>
<l>endif</l>
<l>FileName := path + '/' + ID+'_'+WaferID</l>
<l>try</l>
<l>    try</l>
<l>        tile_images (Image, TiledImage, 1, 'horizontal')</l>
<l>    catch (Exception)</l>
<l>        TiledImage := Image</l>
<l>    endtry</l>
<l>    write_image (TiledImage, imgformat, 0, FileName)</l>
<l>    tuple_split (FileName, '/\\', Substrings)</l>
<l>    FileNameSQL := Substrings[0]</l>
<l>    for Index := 1 to |Substrings|-1 by 1</l>
<l>        FileNameSQL := FileNameSQL+'\\\\'+Substrings[Index]</l>
<l>    endfor</l>
<l>    if (imgformat='jpeg')</l>
<l>        imgformat := 'jpg'</l>
<l>    endif</l>
<l>    FileNameSQL := FileNameSQL+'.'+imgformat</l>
<c></c>
<l>catch (Exception)</l>
<l>endtry</l>
<l>return ()</l>
</body>
<docu id="SaveImage_COPY_1">
<parameters>
<parameter id="FileNameSQL"/>
<parameter id="ID">
<default_type>integer</default_type>
<default_value>20191001083059999</default_value>
<description lang="zh_CN">对应数据库主键ID</description>
<mixed_type>false</mixed_type>
<sem_type>integer</sem_type>
<type_list>
<item>integer</item>
</type_list>
<value_max>301910010830999</value_max>
<value_min>201910010830999</value_min>
</parameter>
<parameter id="Image">
<description lang="zh_CN">要存的图片，如果多相机请将其做成图像数组存入其中</description>
</parameter>
<parameter id="WaferID">
<description lang="zh_CN">通信的id号即该产品的在工厂内编号</description>
<sem_type>any</sem_type>
</parameter>
<parameter id="imgformat">
<default_type>string</default_type>
<default_value>'bmp'</default_value>
<description lang="zh_CN">图片的存图格式</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<type_list>
<item>string</item>
</type_list>
<value_list>
<item>'tiff'</item>
<item>'tiff mask'</item>
<item>'tiff alpha'</item>
<item>'tiff deflate 9'</item>
<item>'tiff deflate 9 alpha'</item>
<item>'tiff jpeg 90'</item>
<item>'tiff lzw'</item>
<item>'tiff lzw alpha '</item>
<item>'tiff packbits'</item>
<item>'bigtiff'</item>
<item>'bigtiff mask'</item>
<item>'bigtiff alpha'</item>
<item>'bigtiff deflate 9'</item>
<item>'bigtiff deflate 9 alpha'</item>
<item>'bigtiff jpeg 90'</item>
<item>'bigtiff lzw'</item>
<item>'bigtiff lzw alpha '</item>
<item>'bigtiff packbits'</item>
<item>'bmp'</item>
<item>'jpeg'</item>
<item>'jpeg 100'</item>
<item>'jpeg 80'</item>
<item>'jpeg 60'</item>
<item>'jpeg 40'</item>
<item>'jpeg 20'</item>
<item>'jp2'</item>
<item>'jp2 50'</item>
<item>'jp2 40'</item>
<item>'jp2 30'</item>
<item>'jp2 20'</item>
<item>'jpegxr'</item>
<item>'jpegxr 50'</item>
<item>'jpegxr 40'</item>
<item>'jpegxr 30'</item>
<item>'jpegxr 20'</item>
<item>'png'</item>
<item>'png best'</item>
<item>'png fastest'</item>
<item>'png none'</item>
<item>'ima'</item>
<item>'hobj'</item>
</value_list>
</parameter>
<parameter id="path">
<default_type>string</default_type>
<default_value>'./image'</default_value>
<description lang="zh_CN">图片存储路径</description>
<mixed_type>false</mixed_type>
<sem_type>filename.dir</sem_type>
<type_list>
<item>string</item>
</type_list>
</parameter>
</parameters>
</docu>
</procedure>
<procedure name="Laser_Engraved_Start">
<interface>
<io>
<par name="EmptyObjectT" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="KX_LocationXStart" base_type="ctrl" dimension="0"/>
<par name="KX_Location1Start" base_type="ctrl" dimension="0"/>
<par name="KX_Location2Start" base_type="ctrl" dimension="0"/>
<par name="KX_compensate" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="JT" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>global tuple QuitTaskFlag</l>
<l>modbus_write_bit (0, 1002, 0)</l>
<l>* modbus_write_bit (0, 212, 1)</l>
<l>* wait_seconds (0)</l>
<l>* modbus_write_bit (0, 212, 0)</l>
<l>modbus_write_bit (0, 1002, 1)</l>
<l>EnQueueLog ('Log', '刻线前调整角度', 212, 1)</l>
<l>modbus_write_bit (0, 176, 1)</l>
<l>EnQueueLog ('Log', '棒子下降刻线', 176, 1)</l>
<l>while (QuitTaskFlag=0)</l>
<l>Read_JT (JT)</l>
<l>    if (JT=2)</l>
<l>        return ()</l>
<l>    endif</l>
<l>Read_Modbus ('bool', 128, 1, YD)</l>
<l>* Read_Modbus ('bool', 176, 1, XJ)</l>
<l>    if (YD=0)</l>
<l>EnQueueLog ('Log', '刻线前确认是否静止', 128, YD)</l>
<l>        break</l>
<l>    endif</l>
<l>endwhile</l>
<l>modbus_write_registerFloat ()</l>
<l>EnQueueLog ('Log', '设置运动速度', 1002, 1500)</l>
<l>Laser_Engraved (EmptyObjectT, KX_LocationXStart+KX_compensate*5, KX_Location1Start, KX_Location2Start, JT)</l>
<l>if (JT=2)</l>
<l>    return ()</l>
<l>endif</l>
<c></c>
<l>modbus_write_registerFloat ()</l>
<l>modbus_write_bit (0, 126, 1)</l>
<l>while (QuitTaskFlag=0)</l>
<l>Read_JT (JT)</l>
<l>    if (JT=2)</l>
<l>        return ()</l>
<l>    endif</l>
<l>Read_Modbus ('bool', 126, 1, YD)</l>
<l>    if (YD=0)</l>
<l>        break</l>
<l>    endif</l>
<l>endwhile</l>
<c></c>
<c></c>
<c></c>
<l>return ()</l>
</body>
<docu id="Laser_Engraved_Start">
<parameters>
<parameter id="EmptyObjectT"/>
<parameter id="JT"/>
<parameter id="KX_Location1Start"/>
<parameter id="KX_Location2Start"/>
<parameter id="KX_LocationXStart"/>
<parameter id="KX_compensate"/>
</parameters>
</docu>
</procedure>
<procedure name="YouEyE_DispImage">
<interface>
<io>
<par name="object" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="WindowHandle" base_type="ctrl" dimension="0"/>
<par name="color" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>try</l>
<l>    get_image_size (object, imgWidth, imgHeight)</l>
<l>    get_window_extents (WindowHandle, Row, Column, winWidth, winHeight)</l>
<l>    ScaleWidth := imgWidth/(winWidth*1.0)</l>
<l>    ScaleHeight := imgHeight/(winHeight*1.0)</l>
<c></c>
<l>    if (ScaleWidth&gt;=ScaleHeight)</l>
<l>        row1 := -(1.0) * ((winHeight * ScaleWidth) - imgHeight) / 2</l>
<l>        column1 := 0</l>
<l>        row2 := row1 + winHeight * ScaleWidth</l>
<l>        column2 := column1 + winWidth * ScaleWidth</l>
<l>    else</l>
<l>        row1 := 0</l>
<l>        column1 := -(1.0) * ((winWidth * ScaleHeight) - imgWidth) / 2</l>
<l>        row2 := row1 + winHeight * ScaleHeight</l>
<l>        column2 := column1 + winWidth * ScaleHeight</l>
<l>    endif</l>
<l>    get_obj_class (object, Class)</l>
<l>    if (Class='image')</l>
<l>        clear_window (WindowHandle)</l>
<l>        set_part (WindowHandle, row1, column1, row2, column2)</l>
<l>    endif</l>
<l>catch (Exception)</l>
<l>endtry</l>
<l>try</l>
<l>    set_color (WindowHandle, color)</l>
<l>catch (Exception)</l>
<l>endtry</l>
<l>disp_obj (object, WindowHandle)</l>
<l>return ()</l>
</body>
<docu id="YouEyE_DispImage">
<abstract lang="zh_CN">该算子能使图像居中显示，你也可以不使用该算子，利用disp_obj自己适配显示，使用该算子时首先要显示image，然后才能显示region</abstract>
<parameters>
<parameter id="WindowHandle">
