<l>set_dict_tuple (LeafDict, 'Competence', Competence)</l>
<l>set_dict_tuple (LeafDict, 'Type', Type)</l>
<l>set_dict_tuple (LeafDict, 'Limit', Limit)</l>
<l>set_dict_tuple (LeafDict, 'Value', DefaultValue)</l>
<c></c>
<l>set_dict_tuple (NodesDict, Leaf, LeafDict)</l>
<c></c>
<c></c>
<c></c>
<l>Value := DefaultValue</l>
<l>return ()</l>
</body>
