<procedure name="EnQueueLog_COPY_1">
<interface>
<ic>
<par name="Catlog" base_type="ctrl" dimension="0"/>
<par name="Meta" base_type="ctrl" dimension="0"/>
<par name="Tags" base_type="ctrl" dimension="0"/>
<par name="Values" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>global def tuple G_RunEngine</l>
<l>get_dict_tuple (G_RunEngine, 'G_Log_Queue', G_Log_Queue)</l>
<l>* get_dict_tuple (G_RunEngine, 'G_Log_QueueEvent', G_Log_QueueEvent)</l>
<c></c>
<l>try</l>
<l>    get_system_time (MSecond, Second, Minute, Hour, Day, YDay, Month, Year)</l>
<l>    Time := YDay+'.'+Hour+':'+Minute+':'+Second+'.'+MSecond</l>
<l>    create_message (MessageLog)</l>
<l>    set_message_tuple (MessageLog, 'Catlog', Catlog+'.txt')</l>
<l>    set_message_tuple (MessageLog, 'Time', Time)</l>
<l>    set_message_tuple (MessageLog, 'Meta', Meta)</l>
<l>    set_message_tuple (MessageLog, 'Tags', Tags)</l>
<l>    set_message_tuple (MessageLog, 'Values', Values)</l>
<l>    enqueue_message (G_Log_Queue, MessageLog, [], [])</l>
<l>    clear_message (MessageLog)</l>
<l>*     signal_event (G_Log_QueueEvent)</l>
<l>catch (Exception)</l>
<l>endtry</l>
<l>return ()</l>
</body>
<docu id="EnQueueLog_COPY_1">
<abstract lang="zh_CN">日志记录函数</abstract>
<parameters>
<parameter id="Catlog">
<default_type>string</default_type>
<default_value>'check'</default_value>
<description lang="zh_CN">日志文件名</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
<values>
<item>'check'</item>
<item>'Exception'</item>
<item>'TCP'</item>
<item>'Engine'</item>
</values>
</parameter>
<parameter id="Meta">
<default_type>string</default_type>
<default_value>类名</default_value>
<description lang="zh_CN">属于哪种类型的日志</description>
<mixed_type>false</mixed_type>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
</parameter>
<parameter id="Tags">
<description lang="zh_CN">项目名，记录的这条日志的项目名称</description>
</parameter>
<parameter id="Values">
<description lang="zh_CN">值，这条日志的对应的项目的值</description>
</parameter>
</parameters>
</docu>
</procedure>
<procedure name="End_All">
<interface>
<ic>
<par name="An_exception_is_reported" base_type="ctrl" dimension="0"/>
<par name="XC" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<c>* *回原点</c>
<l>End_Check (XC)</l>
<c>* *******************************************</c>
<c>* *****************小车交互**************************</c>
<c>* *判断是否有异常*********</c>
<l>n := 0</l>
<l>while (true)</l>
<l>Read_Modbus ('bool', 181, 1, Tuple)</l>
<l>    if (Tuple=1)</l>
<l>        break</l>
<l>    else</l>
<l>        wait_seconds (1)</l>
<l>        n := n+1</l>
<l>        if (n&gt;5)</l>
<l>            modbus_write_register (0, 3500, 1)</l>
<l>*             stop ()</l>
<l>        endif</l>
<c></c>
<l>    endif</l>
<c></c>
<l>endwhile</l>
<l>modbus_write_register (0, 0, 2)</l>
<l>while (true)</l>
<l>* BVCamGrabImagex ()</l>
<l>* Read_Modbus ('int', 2400, 1, Tuple)</l>
<l>Read_Modbus ('int', 100, 1, Tuple)</l>
<c></c>
<l>    if (Tuple=3)</l>
<l>EnQueueLog ('Log', 'AGV告知他已离开', 100, Tuple)</l>
<l>        modbus_write_register (0, 2105, 1)</l>
<l>        while (true)</l>
<l>Read_Modbus ('int', 2009, 1, Tuple)</l>
<l>*             Tuple := 0</l>
<l>            if (Tuple=0)</l>
<l>                modbus_write_bit (0, 810, 1)</l>
<l>                wait_seconds (1)</l>
<l>                modbus_write_bit (0, 810, 0)</l>
<l>EnQueueLog ('Log', '清零完成啦', 810, Tuple)</l>
<l>                break</l>
<l>            endif</l>
<c></c>
<c></c>
<l>        endwhile</l>
<l>        break</l>
<l>    endif</l>
<l>    modbus_write_register (0, 0, 2)</l>
<l>endwhile</l>
<c></c>
<c></c>
<c>* ***********************</c>
<l>return ()</l>
</body>
<docu id="End_All">
<parameters>
<parameter id="An_exception_is_reported"/>
<parameter id="XC"/>
</parameters>
</docu>
</procedure>
<procedure name="Init_Camera_Modbus_Check">
<interface>
<oo>
<par name="Rectangle" base_type="iconic" dimension="0"/>
</oo>
<oc>
<par name="QueueHandle" base_type="ctrl" dimension="0"/>
<par name="Handle" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<c></c>
<c></c>
<c></c>
<l>set_system ('width', 1024)</l>
<l>set_system ('height', 4800*4)</l>
<c></c>
<l>gen_rectangle1 (Rectangle, 0, 0, 100, 1024)</l>
<l>for Index1 := 100 to 4800 by 100</l>
<l>    gen_rectangle1 (Rectangle1, Index1, 0, Index1+100, 1024)</l>
<l>    concat_obj (Rectangle, Rectangle1, Rectangle)</l>
<c></c>
<l>endfor</l>
<l>erosion_rectangle1 (Rectangle, Rectangle, 640, 1)</l>
<c></c>
<c></c>
<l>try</l>
<l>create_message_queue (QueueHandle)</l>
<l>BVCamOpenByUID ('YL', 1, QueueHandle, Handle)</l>
<l>BVCamStartGrab (Handle)</l>
<l>* Hik_openCamera ( 'YL', 1, QueueHandle, Handle)</l>
<l>*  Hik_StartPhotograph (Handle)</l>
<l>EnQueueLog ('Log', '打开BV相机', 'SC_YL', ' ')</l>
<l>catch (Exception)</l>
<l>EnQueueLog ('Log', '打开BV相机失败', 'SC_YL', ' ')</l>
<l>endtry</l>
<c></c>
<c></c>
<l>return ()</l>
</body>
<docu id="Init_Camera_Modbus_Check">
<parameters>
<parameter id="Handle"/>
<parameter id="QueueHandle"/>
<parameter id="Rectangle"/>
</parameters>
</docu>
</procedure>
<procedure name="Craete_DISPImage">
<interface>
<io>
<par name="Image1sOut" base_type="iconic" dimension="0"/>
<par name="SelectedRegions" base_type="iconic" dimension="0"/>
</io>
<oo>
<par name="ImageDUMP" base_type="iconic" dimension="0"/>
</oo>
</interface>
<body>
<l>Image1sOutOut := Image1sOut</l>
<c></c>
<l>scale_image_max (Image1sOutOut, ImageScaleMax)</l>
<l>*zoom_image_size (ImageScaleMax, ImageScaleMax, 1920, 640, 'constant')</l>
<l>get_image_size (ImageScaleMax, Width, Height)</l>
<l>open_window (0, 0, Width, Height, 0, 'buffer', '', WindowHandle)</l>
<l>set_part (WindowHandle, 0, 0, Height-1, Width-1)</l>
<l>disp_image (ImageScaleMax, WindowHandle)</l>
<l>dilation_rectangle1 (SelectedRegions, RegionDilation, 100, 100)</l>
<l>shape_trans (RegionDilation, RegionTrans, 'rectangle1')</l>
<l>set_line_width(WindowHandle, 5)</l>
<l>set_draw (WindowHandle, 'margin')</l>
<l>set_color (WindowHandle, 'red')</l>
<l>query_font (WindowHandle, Font)</l>
<l>set_font (WindowHandle, Font[0]+'-Bold-54')</l>
<l>disp_obj (RegionTrans, WindowHandle)</l>
<l>dump_window_image (ImageDUMP, WindowHandle)</l>
<l>close_window (WindowHandle)</l>
<l>return ()</l>
</body>
<docu id="Craete_DISPImage">
<parameters>
<parameter id="Image1sOut"/>
<parameter id="ImageDUMP"/>
<parameter id="SelectedRegions"/>
</parameters>
</docu>
</procedure>
<procedure name="RedisThread">
<interface>
<ic>
<par name="DBIndex" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>global tuple G_RunEngine</l>
<l>global tuple QuitTaskFlag</l>
<l>global tuple G_ParmDict</l>
<c></c>
<l>create_message_queue (G_Redis_Queue)</l>
<l>set_dict_tuple (G_RunEngine, 'G_Redis_Queue', G_Redis_Queue)</l>
<l>while (QuitTaskFlag=0)</l>
<l>    while (QuitTaskFlag=0)</l>
<l>        try</l>
<l>            open_socket_connect ('127.0.0.1', 3000, ['protocol','timeout'], ['HALCON',6], Socket)</l>
<l>            set_dict_tuple (G_RunEngine, 'Socket', Socket)</l>
<l>            break</l>
<l>        catch (Exception)</l>
<l>        endtry</l>
<l>    endwhile</l>
<l>    while (QuitTaskFlag=0)</l>
<l>        try</l>
<l>            dequeue_message (G_Redis_Queue, 'timeout', 1, MessageRedis)</l>
<l>            get_message_param (MessageRedis, 'key_data_type', 'ChannelData', GenParamValue)</l>
<l>            if (GenParamValue='object')</l>
<l>                get_message_obj (ObjectData, MessageRedis, 'ChannelData')</l>
<l>                try</l>
<l>                    send_image (ObjectData, Socket)</l>
<l>                catch (Exception)</l>
<l>                    close_socket (Socket)</l>
<l>                    clear_message (MessageRedis)</l>
<l>                    break</l>
<l>                endtry</l>
<l>             get_message_param (MessageRedis, 'key_data_type', 'tuple', GenParamValue)   </l>
<l>                get_message_tuple (MessageRedis, 'tuple', TupleData)</l>
<l>                try</l>
<l>                    send_tuple (Socket, TupleData)</l>
<l>                catch (Exception)</l>
<l>                    close_socket (Socket)</l>
<l>                    clear_message (MessageRedis)</l>
<l>                    break</l>
<l>                endtry</l>
<c>                </c>
<l>            endif</l>
<l>            clear_message (MessageRedis)</l>
<l>        catch (Exception)</l>
<l>*             try</l>
<c></c>
<c></c>
<l>*                 get_next_socket_data_type (Socket, DataType)</l>
<l>*                 if (DataType='tuple')</l>
<l>*                     receive_tuple (Socket, Tuple)</l>
<l>*                     if (Tuple='end' or Tuple='End' or Tuple='END')</l>
<l>*                         QuitTaskFlag := 1</l>
<l>*                     else</l>
<l>*                         try</l>
<l>*                             json_to_dict (Tuple, [], [], DictHandle)</l>
<l>*                             G_ParmDict := DictHandle</l>
<l>*                         catch (Exception)</l>
<l>* EnQueueLog ('Log', '错误', '收到的json不符合格式', Tuple)</l>
<l>*                         endtry</l>
<l>*                     endif</l>
<l>*                 endif</l>
<l>*             catch (Exception)</l>
<l>*                 break</l>
<l>*             endtry</l>
<l>        endtry</l>
<l>    endwhile</l>
<l>endwhile</l>
<c></c>
<l>try</l>
<l>    close_socket (Socket)</l>
<l>    clear_message (MessageRedis)</l>
<l>catch (Exception)</l>
<l>endtry</l>
<l>return ()</l>
</body>
<docu id="RedisThread">
<parameters>
<parameter id="DBIndex"/>
</parameters>
</docu>
</procedure>
<procedure name="LogThread">
<interface/>
<body>
<l>global tuple G_RunEngine</l>
<l>global tuple QuitTaskFlag</l>
<l>create_message_queue (G_Log_Queue)</l>
<l>set_dict_tuple (G_RunEngine, 'G_Log_Queue', G_Log_Queue)</l>
<l>* create_event ([], [], G_Log_QueueEvent)</l>
<l>* set_dict_tuple (G_RunEngine, 'G_Log_QueueEvent', G_Log_QueueEvent)</l>
<l>while (QuitTaskFlag=0)</l>
<l>    try</l>
<l>        dequeue_message (G_Log_Queue, 'timeout', 1, MessageLog)</l>
<l>        get_message_tuple (MessageLog, 'Catlog', FileName)</l>
<l>        get_message_tuple (MessageLog, 'Time', Time)</l>
<l>        get_message_tuple (MessageLog, 'Meta', Meta)</l>
<l>        get_message_tuple (MessageLog, 'Tags', Tags)</l>
<l>        get_message_tuple (MessageLog, 'Values', Values)</l>
<l>        clear_message (MessageLog)</l>
<l>        get_system_time (MSecond, Second, Minute, Hour, Day, YDay, Month, Year)</l>
<l>        DateToday := Year + '.'+ Month + '.' + Day</l>
<l>        Dir := './log/'+DateToday+'/'</l>
<l>        file_exists (Dir +  FileName, FileExists)</l>
<l>        if (FileExists=0)</l>
<l>            file_exists (Dir, DirExsists)</l>
<l>            if (DirExsists=0)</l>
<l>                tuple_split (Dir, '/', SubDir)</l>
<l>                CurrentDir := ''</l>
<l>                for i := 0 to |SubDir|-1 by 1</l>
<l>                    CurrentDir := CurrentDir+SubDir[i]+'/'</l>
<l>                    file_exists (CurrentDir, FileExists)</l>
<l>                    if (FileExists=0)</l>
<l>                        make_dir (CurrentDir)</l>
<l>                    endif</l>
<l>                endfor</l>
<l>            endif</l>
<l>            open_file (Dir + FileName, 'append', FileHandle)</l>
<l>            Head := 'DateTime'</l>
<l>            fwrite_string (FileHandle, Head)</l>
<l>            fnew_line (FileHandle)</l>
<l>        else</l>
<l>            open_file (Dir + FileName, 'append', FileHandle)</l>
<l>            fwrite_string (FileHandle, Time+'\t'+Meta+'\t')</l>
<l>            FileString := Tags+'\t'+Values</l>
<l>            fwrite_string (FileHandle, FileString)</l>
<l>            fnew_line (FileHandle)</l>
<l>        endif</l>
<l>        close_file (FileHandle)</l>
<l>    catch (Exception)</l>
<l>    endtry</l>
<l>endwhile</l>
<l>return ()</l>
</body>
<docu id="LogThread">
<parameters/>
</docu>
</procedure>
<procedure name="LogException_COPY_1">
<interface>
<ic>
<par name="Exception" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="Ex" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>Ex := Exception[0]+' '+Exception[2]+'在'+Exception[7] + '函数的'+Exception[5]+'算子'+Exception[4]+'行'</l>
<c>* hv_Ex = new HTuple();</c>
<c>* hv_Ex.Dispose();</c>
<c>* using (HDevDisposeHelper dh = new HDevDisposeHelper())</c>
<c>* {</c>
<c>*    hv_Ex = hv_Exception.OArr[1].ToString();</c>
<c>* }</c>
<l>return ()</l>
</body>
<docu id="LogException_COPY_1">
<parameters>
<parameter id="Ex"/>
<parameter id="Exception"/>
</parameters>
</docu>
</procedure>
<procedure name="Init_Leaf">
<interface>
