<par name="width" base_type="ctrl" dimension="0"/>
<par name="height" base_type="ctrl" dimension="0"/>
<par name="Mode" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="WindowHandle" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>if (height=300 and width=224)</l>
<l>    open_window (0, 0, width, height, 0, Mode, '', WindowHandle)</l>
<l>    set_font (WindowHandle, '黑体-Bold-20')</l>
<l>else</l>
<l>    open_window (0, 0, width, int(height+0.08*height), 0, Mode, '', WindowHandle)</l>
<l>    set_font (WindowHandle, '黑体-Bold-'+int(50))</l>
<l>    set_line_width (WindowHandle, int(max([width,height])*0.0002))</l>
<l>endif</l>
<l>set_draw (WindowHandle, 'margin')</l>
<l>return ()</l>
</body>
