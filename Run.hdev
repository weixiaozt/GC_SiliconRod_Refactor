<?xml version="1.0" encoding="UTF-8"?>
<hdevelop file_version="1.2" halcon_version="23.11.0.0">
<procedure name="main">
<interface/>
<body>
<l>Run (3000)</l>
<c></c>
</body>
<docu id="main">
<parameters/>
</docu>
</procedure>
<procedure name="Init_Chipping">
<interface>
<oc>
<par name="DictHandle" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>set_system ('width', 5120)</l>
<l>set_system ('height', 5120)</l>
<c></c>
<l>try</l>
<c>    </c>
<l>    read_object (Chippingintersectionsmall, './algorithm/ChippingintersectionSmall.hobj')</l>
<l>catch (Exception)</l>
<l>    LogException (Exception, Ex)</l>
<l>    Log ('Exception', Exception)</l>
<l>    gen_rectangle1 (Chippingintersectionsmall, 0, 0, 4096, 4096)</l>
<l>endtry</l>
<c></c>
<c></c>
<l>try</l>
<l>    read_object (chippingMask, './algorithm/硅脱Mask.hobj')</l>
<l>catch (Exception)</l>
<l>    LogException (Exception, Ex)</l>
<l>    Log ('Exception', Exception)</l>
<l>    gen_empty_obj (chippingMask)</l>
<l>endtry</l>
<l>create_dict (DictHandle)</l>
<l>set_dict_object (chippingMask, DictHandle, 'Mask')</l>
<l>set_dict_object (Chippingintersectionsmall, DictHandle, 'Chippingintersectionsmall')</l>
<c></c>
<l>return ()</l>
</body>
<docu id="Init_Chipping">
<parameters>
<parameter id="DictHandle"/>
</parameters>
</docu>
</procedure>
<procedure name="LoadParam">
<interface>
<ic>
<par name="G_ParmDict" base_type="ctrl" dimension="0"/>
<par name="Model" base_type="ctrl" dimension="0"/>
<par name="Nodes" base_type="ctrl" dimension="0"/>
<par name="Leaf" base_type="ctrl" dimension="0"/>
<par name="DefaultValue" base_type="ctrl" dimension="0"/>
<par name="Competence" base_type="ctrl" dimension="0"/>
<par name="Type" base_type="ctrl" dimension="0"/>
<par name="Limit" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="Value" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<c></c>
<l>LoadParams (G_ParmDict, [Model,Nodes,Leaf], 0, DefaultValue, Competence,Type, Limit, Value)</l>
<c></c>
<l>return ()</l>
</body>
<docu id="LoadParam">
<abstract lang="zh_CN">我们的参数采取jason的形式去存储，拥有三个层级[Model][node][KeyName],这三样对应到软件界面即“标签页”、“树状图”、“lable”
其KeyName对应的属性有
["Value"]          输出的参数值
["type"]           该参数的数据类型
["Competence"]     管理权限
["Limit"]           参数限制
以下是一个示例表现其用法我们以[初始化设置][网口设置][IP地址]
{
"初始化设置" : 
{
"网口设置" : 
{
      "IP地址": {
        "Competence": 2,
        "Value": "192.168.1.1",
        "type": "string",
        "Limit": [-2500000,25000000]
 
      },
      "端口号": {
        "Competence": 1,
        "Value": 2000,
        "type": "int",
        "Limit": [ -2500000, 25000000 ]
      }
}
}
}</abstract>
<parameters>
<parameter id="Competence">
<default_type>integer</default_type>
<default_value>1</default_value>
<description lang="zh_CN">管理权限，这个权限有三级，”操作员”（1），”工程师”（2），”厂商”（3）,拥有不同密码，密码在config文件下明码修改，输入对应密码后显示对应参数。</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<sem_type>integer</sem_type>
<type_list>
<item>integer</item>
</type_list>
<value_list>
<item>1</item>
<item>2</item>
<item>3</item>
</value_list>
<value_max>3</value_max>
<value_min>1</value_min>
</parameter>
<parameter id="DefaultValue">
<description lang="zh_CN">没有参数时输出的默认值</description>
<sem_type>any</sem_type>
</parameter>
<parameter id="G_ParmDict"/>
<parameter id="Leaf">
<default_type>string</default_type>
<description lang="zh_CN">标签， 参数的名称</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
</parameter>
<parameter id="Limit">
<description lang="zh_CN">参数限制，在参数类型是数字类时做大小限制的限制，是一个数组，第 一位最小值，第二位是最大值，参数类型是枚举时该参数为被枚举所有元 素</description>
<multivalue>optional</multivalue>
<sem_type>any</sem_type>
</parameter>
<parameter id="Model">
<default_type>string</default_type>
<description lang="zh_CN">一级目录，显示为标签页</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
</parameter>
<parameter id="Nodes">
<default_type>string</default_type>
<description lang="zh_CN">二级目录，显示为树状图</description>
<mixed_type>false</mixed_type>
<multivalue>optional</multivalue>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
</parameter>
<parameter id="Type">
<default_type>string</default_type>
<default_value>int</default_value>
<description lang="zh_CN">当你解析好界面上的参数["Value"]以什么数据类型 输出，详见附录“数据类型与控件对应”</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
<value_list>
<item>'int'</item>
<item>'float'</item>
<item>'bool'</item>
<item>'int[]'</item>
<item>'float[]'</item>
<item>'string'</item>
<item>'string[]'</item>
<item>'string_enum'</item>
<item>'int_enum'</item>
<item>'float_enum'</item>
<item>'path'</item>
</value_list>
</parameter>
<parameter id="Value">
<description lang="zh_CN">输出的参数值</description>
<sem_type>any</sem_type>
</parameter>
</parameters>
</docu>
</procedure>
<procedure name="LogException">
<interface>
<ic>
<par name="Exception" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="Ex" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>        Ex:=Exception[0]+' '+Exception[2]+'在'+Exception[7] + '函数的'+Exception[5]+'算子'+Exception[4]+'行'//导出c#时请使用下面的代码</l>
<c>        *hv_Ex = new HTuple();</c>
<c>        *hv_Ex.Dispose();</c>
<c>        *using (HDevDisposeHelper dh = new HDevDisposeHelper())</c>
<c>        *{</c>
<c>        *    hv_Ex = hv_Exception.OArr[1].ToString();</c>
<c>        *}</c>
<l>return ()</l>
</body>
<docu id="LogException">
<parameters>
<parameter id="Ex"/>
<parameter id="Exception"/>
</parameters>
</docu>
</procedure>
<procedure name="Chipping_Threshold">
<interface>
<io>
<par name="Cell" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="RegionDictHandle" base_type="ctrl" dimension="0"/>
<par name="ChippingHandle" base_type="ctrl" dimension="0"/>
<par name="HalconClassHandle" base_type="ctrl" dimension="0"/>
<par name="G_ParmDict" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>    get_dict_object (Chippingintersectionsmall, ChippingHandle, 'Chippingintersectionsmall')</l>
<l>LoadParam (G_ParmDict, '检测参数', '破片分割', '阈值Max', 240, 3, 'int', [0,255], ThVALMax)</l>
<l>LoadParam (G_ParmDict, '检测参数', '破片分割', '阈值Min', 50, 3, 'int', [0,255], ThVALMin)</l>
<l>    threshold (Cell, Regions, ThVALMin, ThVALMax)</l>
<l>    connection (Regions, ConnectedRegions1)</l>
<l>    select_shape_std (ConnectedRegions1, SelectedRegions, 'max_area', 70)</l>
<l>    fill_up (SelectedRegions, Regions)</l>
<l>LoadParam (G_ParmDict, '检测参数', '破片分割', '开操作去毛刺', 3.5, 3, 'float', [0.5,30.1], opennThVALMin)</l>
<c></c>
<c>    </c>
<l>    opening_circle (Regions, Regions, opennThVALMin)</l>
<c></c>
<c>    ****************************************************************************************************</c>
<l>    intersection (Chippingintersectionsmall, Regions, RegionIntersection)</l>
<l>    select_obj (Chippingintersectionsmall, ObjectSelected, 10)</l>
<l>    region_features (ObjectSelected, 'width', Value)</l>
<l>    select_shape (RegionIntersection, SelectedRegions2, 'area', 'and', 1, Value*Value-1)</l>
<l>    shape_trans (SelectedRegions2, RegionTrans, 'convex')</l>
<l>    difference (RegionTrans, RegionIntersection, RegionDifference)</l>
<l>    union1 (RegionDifference, RegionUnion)</l>
<l>    connection (RegionUnion, ConnectedRegions2)</l>
<l>LoadParam (G_ParmDict, '检测参数', '破片分割', '小破片内接圆半径', 1.5, 2, 'float', [0.5,9999], smallinner_radius)</l>
<l>    select_shape (ConnectedRegions2, SelectedRegions1, 'inner_radius', 'and', smallinner_radius, 99999)</l>
<l>    union1 (SelectedRegions1, RegionUnion1)</l>
<l>    closing_rectangle1 (RegionUnion1, RegionClosing, 512, 512)</l>
<l>    connection (RegionClosing, ChippingRegions)</l>
<c>    ******************************************************************************************************</c>
<l>    opening_circle (RegionDifference, Mask, 15)</l>
<l>    dilation_circle (Mask, Mask, 23.5)</l>
<l>    difference (ChippingRegions, Mask, ChippingRegionsT)</l>
<l>    intersection (ChippingRegions, Mask, ChippingRegionsTT)</l>
<l>LoadParam (G_ParmDict, '检测参数', '破片分割', '倒角破片内接圆半径', 2.5, 2, 'float', [0.5,9999], inner_radius)</l>
<l>    connection (ChippingRegionsTT, ChippingRegionsTT)</l>
<l>    select_shape (ChippingRegionsTT, SelectedRegions1, 'inner_radius', 'and', inner_radius, 99999)</l>
<l>    union2 (ChippingRegionsT, SelectedRegions1, ChippingRegions)</l>
<c></c>
<c>********************************************************</c>
<l>LoadParam (G_ParmDict, '检测参数', '破片分割', '开启AI分类', '是', 2, 'string_enum', ['是','否'], classF)</l>
<l>    if(classF='是')</l>
<l>        connection (ChippingRegions, ConnectedRegions)</l>
<l>        get_dict_tuple (HalconClassHandle, '权重', DLModelHandle)</l>
<l>        get_dict_tuple (HalconClassHandle, '配置', DLPreprocessParam)</l>
<l>        get_dict_tuple (HalconClassHandle, '分类尺寸', MAX_SIZE)</l>
<l>        MAX_SIZE:=int(MAX_SIZE/2)</l>
<l>    Ai_Clase_Region_Chipping_COPY_1 (Cell, ConnectedRegions, G_ParmDict, RegionDictHandle, 5, DLPreprocessParam, DLModelHandle, ['崩边','缺口','叠片','薄片','线痕','抖动','隐裂'], MAX_SIZE)</l>
<c></c>
<l>    else</l>
<l>        set_dict_object (ChippingRegions, RegionDictHandle, '缺口')</l>
<l>    endif</l>
<c>     </c>
<c></c>
<l>return ()</l>
</body>
<docu id="Chipping_Threshold">
<parameters>
<parameter id="Cell"/>
<parameter id="ChippingHandle"/>
<parameter id="G_ParmDict"/>
<parameter id="HalconClassHandle"/>
<parameter id="RegionDictHandle"/>
</parameters>
</docu>
</procedure>
<procedure name="crack_threshold">
<interface>
<io>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="RegionDictHandle" base_type="ctrl" dimension="0"/>
<par name="HalconClassHandle" base_type="ctrl" dimension="0"/>
<par name="G_ParmDict" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>    ImageT:=Image</l>
<l>    threshold (Image, Regions, 0, 240)</l>
<l>    connection (Regions, ConnectedRegions)</l>
<l>    select_shape_std (ConnectedRegions, SelectedRegions, 'max_area', 70)</l>
<l>    fill_up (SelectedRegions, RegionFillUp)</l>
<c>    ***************穿孔</c>
<l>    threshold (Image, CCCCCCCCCCCCCCC, 250, 255)</l>
<l>    intersection (CCCCCCCCCCCCCCC, RegionFillUp, RegionIntersection)</l>
<l>    try</l>
<l>        get_dict_object (Object, RegionDictHandle, '穿孔')</l>
<l>        union2 (Object, RegionIntersection, RegionIntersection)</l>
<l>    catch (Exception)</l>
<l>    endtry</l>
<l>    set_dict_object(RegionIntersection,RegionDictHandle, '穿孔')</l>
<c>    ***************穿孔</c>
<c>    </c>
<c>    </c>
<c>    </c>
<l>LoadParam (G_ParmDict, '检测参数', '裂纹分割', '腐蚀度', 11, 3, 'int', [0,4000], erosionV)</l>
<l>    erosion_rectangle1 (RegionFillUp, RegionErosion, erosionV, erosionV)</l>
<l>    union1 (RegionErosion, RegionErosion)</l>
<c>    </c>
<l>    complement (RegionErosion, RegionComplement)</l>
<l>    paint_region (RegionComplement, Image, Image, 0, 'fill')</l>
<l>LoadParam (G_ParmDict, '检测参数', '裂纹分割', '均值滤波', 15, 3, 'int', [0,4000], meanMask)</l>
<l>    gray_closing_rect (Image, ImageMeanx, 1, meanMask)</l>
<l>    gray_closing_rect (Image, ImageMeany, meanMask, 1)</l>
<l>LoadParam (G_ParmDict, '检测参数', '裂纹分割', '对比度', 14, 3, 'int', [0,4000], contrast)</l>
<l>    dyn_threshold (Image, ImageMeanx, RegionDynThreshx, contrast, 'dark')</l>
<l>    dyn_threshold (Image, ImageMeany, RegionDynThreshy, contrast, 'dark')</l>
<l>    intersection (RegionDynThreshx, RegionDynThreshy, RegionDynThresh)</l>
<l>LoadParam (G_ParmDict, '检测参数', '裂纹分割', '外接圆筛选', 5.5, 3, 'float', [0,4000], outerV)</l>
<l>    intersection (RegionDynThresh, RegionErosion, ConnectedRegions1)</l>
<l>    closing_circle (ConnectedRegions1, ConnectedRegions1, real(outerV)/2+1)</l>
<c>    </c>
<l>    connection (ConnectedRegions1, ConnectedRegions1)</l>
<c>    </c>
<l>    select_shape (ConnectedRegions1, crack, 'width', 'and', outerV, 999999)//隐裂</l>
<l>    select_shape (crack, crack, 'height', 'and', outerV, 999999)//隐裂</l>
<l>    union1 (crack, crack)</l>
<l>    closing_rectangle1 (crack, crack, 256, 256)</l>
<c>    </c>
<c>    </c>
<l>LoadParam (G_ParmDict, '检测参数', '裂纹分割', '开启AI分类', '是', 2, 'string_enum', ['是','否'], classF)</l>
<l>    if(classF='是')</l>
<l>        connection (crack, ConnectedRegions)</l>
<l>        get_dict_tuple (HalconClassHandle, '权重', DLModelHandle)</l>
<l>        get_dict_tuple (HalconClassHandle, '配置', DLPreprocessParam)</l>
<l>        get_dict_tuple (HalconClassHandle, '分类尺寸', MAX_SIZE)</l>
<l>        MAX_SIZE:=int(MAX_SIZE/2)</l>
<l>        Ai_Clase_Region_Chipping_COPY_1 (Image, ConnectedRegions, G_ParmDict, RegionDictHandle, 5, DLPreprocessParam, DLModelHandle, ['隐裂','叠片','脏污','崩边','线痕'], MAX_SIZE)</l>
<l>        try</l>
<l>              get_dict_object (Object1, RegionDictHandle, '崩边')</l>
<l>              get_dict_object (Object2, RegionDictHandle, '隐裂')</l>
<l>              union2 (Object1, Object2, crack)</l>
<l>              set_dict_object(crack,RegionDictHandle, 'Region')</l>
<l>        catch (Exception)</l>
<l>        endtry</l>
<c>      </c>
<c>    </c>
<l>    else</l>
<l>          try</l>
<l>             get_dict_object (Object, RegionDictHandle, '隐裂')</l>
<l>             union2 (Object, crack, crack)</l>
<l>        catch (Exception)</l>
<l>        endtry</l>
<l>        set_dict_object(crack,RegionDictHandle, 'Region')</l>
<l>    endif</l>
<c> </c>
<l>return ()</l>
</body>
<docu id="crack_threshold">
<parameters>
<parameter id="G_ParmDict"/>
<parameter id="HalconClassHandle"/>
<parameter id="Image"/>
<parameter id="RegionDictHandle"/>
</parameters>
</docu>
</procedure>
<procedure name="horn_threshold">
<interface>
<io>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<oo>
<par name="SelectedXLD" base_type="iconic" dimension="0"/>
</oo>
<ic>
<par name="RegionDict" base_type="ctrl" dimension="0"/>
<par name="G_ParmDict" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>    threshold (Image, Regions, 0, 240)</l>
<l>    opening_rectangle1 (Regions, RegionOpening, 200, 1)</l>
<l>    connection (RegionOpening, ConnectedRegions)</l>
<l>    select_shape_std (ConnectedRegions, SelectedRegions, 'max_area', 70)</l>
<l>    gen_contour_region_xld (SelectedRegions, Contours, 'border')</l>
<l>    segment_contours_xld (Contours, ContoursSplit, 'lines', 5, 3, 1)</l>
<l>    fit_line_contour_xld (ContoursSplit, 'tukey', -1, 0, 5, 2, RowBegin, ColBegin, RowEnd, ColEnd, Nr, Nc, Dist)</l>
<l>    gen_region_line (ROI_0, RowBegin, ColBegin, RowEnd, ColEnd)</l>
<l>    LoadParam (G_ParmDict, '检测参数', '倒角分割', '倒角斜度', 20, 3, 'float', [0.5,9999], Phi)</l>
<l>    n := Phi</l>
<l>    select_shape (ROI_0, SelectedRegions1, ['phi','phi'], 'or', [0.785399-0.017453*n,-0.785399-0.017453*n], [0.785399+0.017453*n,-0.785399+0.017453*n])</l>
<l>    count_obj (SelectedRegions1, NumberSS)//非直边数量</l>
<l>    union1 (SelectedRegions1, RegionUnion)</l>
<l>    closing_circle (RegionUnion, RegionClosing, 3.5)</l>
<l>    connection (RegionClosing, ConnectedRegions1)</l>
<l>    LoadParam (G_ParmDict, '检测参数', '倒角分割', '倒角筛选长度', 10.1, 3, 'float', [0.5,9999], outer_radiusPhi)</l>
<l>    select_shape (ConnectedRegions1, SelectedXLD, 'outer_radius', 'and', outer_radiusPhi, 999999)</l>
<l>    region_features (SelectedXLD, 'outer_radius', outer_radiusValue)</l>
<c></c>
<l>    if(NumberSS&gt;4  and |outer_radiusValue|=4)//只碎倒角的角的缺角</l>
<l>        set_dict_object(RegionUnion,RegionDict, '缺角')</l>
<l>    endif</l>
<c>    </c>
<l>    LoadParam (G_ParmDict, '检测参数', '倒角分割', '缺角尺寸', 20, 2, 'float', [0.5,9999], xXXL_radius)</l>
<l>try</l>
<l>    CC := max(outer_radiusValue)-min(outer_radiusValue)</l>
<l>catch (Exception)</l>
<l>    CC :=100</l>
<l>endtry</l>
<l>LoadParam (G_ParmDict, '检测参数', '倒角分割', '缺角比对尺寸', 15, 3, 'float', [0.5,9999], max_min_radius)</l>
<c></c>
<l>    if (CC&gt;max_min_radius and |outer_radiusValue|=4)</l>
<l>        select_shape (SelectedXLD, SelectedXLD, 'outer_radius', 'and', xXXL_radius, 999999)</l>
<l>    else</l>
<l>        select_shape (SelectedXLD, SelectedXLD, 'outer_radius', 'and', xXXL_radius*1.5, 999999)</l>
<l>    endif</l>
<l>    try</l>
<l>        get_dict_object(EmptyObject,RegionDict, '缺角')</l>
<l>    catch (Exception)</l>
<l>        gen_empty_obj (EmptyObject)</l>
<l>    endtry</l>
<l>    union2 (EmptyObject, SelectedXLD, RegionUnion1)</l>
<l>    set_dict_object(RegionUnion1,RegionDict, '缺角')</l>
<c></c>
<l>return ()</l>
</body>
<docu id="horn_threshold">
<parameters>
<parameter id="G_ParmDict"/>
<parameter id="Image"/>
<parameter id="RegionDict"/>
<parameter id="SelectedXLD"/>
</parameters>
</docu>
</procedure>
<procedure name="SiliconFall_threshold">
<interface>
<io>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="RegionDict" base_type="ctrl" dimension="0"/>
<par name="HalconClassHandle" base_type="ctrl" dimension="0"/>
<par name="G_ParmDict" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>       get_image_size (Image, Width, Height)</l>
<l>       if(Width&lt;4096)</l>
<l>           zoom_image_factor (Image, ImageZoom, 2, 2, 'constant')</l>
<l>       else</l>
<l>           ImageZoom:=Image</l>
<l>       endif</l>
<l>            threshold (ImageZoom, Regions, 0, 240)</l>
<l>            connection (Regions, ConnectedRegions1)</l>
<l>            select_shape_std (ConnectedRegions1, SelectedRegions, 'max_area', 70)</l>
<l>            fill_up (SelectedRegions, Regions)</l>
<l>            erosion_circle (Regions, RegionErosion, 3.5)</l>
<l>            gen_contour_region_xld (RegionErosion, Contours, 'border')            </l>
<l>            gen_region_contour_xld (Contours, Region1, 'margin')</l>
<c></c>
<l>LoadParam (G_ParmDict, '检测参数', '硅落分割', '微小破片掩膜', 7, 2, 'float', [0.5,9999], inner_radiusMask)</l>
<l>LoadParam (G_ParmDict, '检测参数', '硅落分割', '微小破片对比度', 93, 2, 'int', [0,254], Thval)</l>
<l>            gray_opening_rect (ImageZoom, ImageOpening, inner_radiusMask, inner_radiusMask)</l>
<l>            gray_closing_rect (ImageZoom, ImageClosing, inner_radiusMask, inner_radiusMask)</l>
<l>            sub_image (ImageOpening,ImageClosing,  ImageSub, 1, 128)</l>
<l>            threshold (ImageSub, Regions, 0, Thval)</l>
<l>            closing_circle (Regions, Regions,  real(inner_radiusMask)/2)</l>
<l>            connection (Regions, ConnectedRegions)</l>
<l>LoadParam (G_ParmDict, '检测参数', '硅落分割', '微小破片内接圆', 1.5, 2, 'float', [0.5,9999], SSinner_radius)</l>
<l>            select_shape (ConnectedRegions, SelectedRegions, 'inner_radius', 'and',SSinner_radius, 6)</l>
<l>            dilation_circle (Region1, RegionDilation, 4)</l>
<l>            intersection (RegionDilation, SelectedRegions, RegionIntersection)</l>
<c>            </c>
<l>            if(Width&lt;4096)</l>
<l>                zoom_region (RegionIntersection, RegionIntersection, 0.5, 0.5)</l>
<c></c>
<l>            endif</l>
<c>          </c>
<c>            </c>
<l>LoadParam (G_ParmDict, '检测参数', '硅落分割', '开启AI分类', '是', 2, 'string_enum', ['是','否'], classF)</l>
<c>            </c>
<l>            if(classF='是')</l>
<l>                connection (RegionIntersection, ConnectedRegions)</l>
<l>                get_dict_tuple (HalconClassHandle, '权重', DLModelHandle)</l>
<l>                get_dict_tuple (HalconClassHandle, '配置', DLPreprocessParam)</l>
<l>                get_dict_tuple (HalconClassHandle, '分类尺寸', MAX_SIZE)</l>
<l>                Ai_Clase_Region_Chipping_COPY_1 (Image, ConnectedRegions, G_ParmDict, RegionDict, 5, DLPreprocessParam, DLModelHandle, ['崩边','缺口','叠片','薄片','线痕','抖动'], MAX_SIZE)</l>
<c></c>
<l>            else</l>
<l>                try</l>
<l>                    get_dict_object (Object, RegionDict,'崩边')</l>
<l>                    union2 (Object, RegionIntersection, RegionIntersection)</l>
<l>                catch (Exception)</l>
<l>                endtry</l>
<l>                set_dict_object(RegionIntersection,RegionDict, '崩边')</l>
<l>            endif</l>
<c>            </c>
<c></c>
<l>return ()</l>
</body>
<docu id="SiliconFall_threshold">
<parameters>
<parameter id="G_ParmDict"/>
<parameter id="HalconClassHandle"/>
<parameter id="Image"/>
<parameter id="RegionDict"/>
</parameters>
</docu>
</procedure>
<procedure name="analyse_Shape_Class_Dll">
<interface>
<io>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="G_ParmDict" base_type="ctrl" dimension="0"/>
<par name="AllQualitys" base_type="ctrl" dimension="0"/>
<par name="IDTime" base_type="ctrl" dimension="0"/>
<par name="RegionDictHandle" base_type="ctrl" dimension="0"/>
<par name="Grade" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>get_dict_param (RegionDictHandle, 'keys', [], XidiName)</l>
<l>for xidiIndex := 0 to |XidiName|-1 by 1</l>
<l>    get_dict_object(Region,RegionDictHandle, XidiName[xidiIndex])</l>
<l>    connection (Region, ConnectedRegions)</l>
<l>    LoadParam (G_ParmDict, '检测参数', XidiName[xidiIndex]+Grade, '面积筛选', 1000, 3, 'int', [0,25000000], AreaVal)</l>
<l>    select_shape (ConnectedRegions, SelectedRegions, 'area', 'and', AreaVal, 25000000)</l>
<l>    union1 (SelectedRegions, RegionUnion)</l>
<l>    connection (RegionUnion, ConnectedRegions1)</l>
<l>    region_features (ConnectedRegions1, 'area', AreaValue)</l>
<l>    LoadParam (G_ParmDict, '检测参数', XidiName[xidiIndex]+Grade, '允许最大面积', 1000, 1, 'int', [0,25000000], MaxAreaVal)</l>
<l>    LoadParam (G_ParmDict, '检测参数', XidiName[xidiIndex]+Grade, '允许总面积', 1000, 1, 'int', [0,25000000], SumAreaVal)</l>
<l>    LoadParam (G_ParmDict, '检测参数', XidiName[xidiIndex]+Grade, '允许个数', 1000, 1, 'int', [0,25000000], NumVal)</l>
<l>    LoadParam (G_ParmDict, '检测参数', XidiName[xidiIndex]+Grade, '允许最大长度', 1000, 1, 'int', [0,25000000], outer_radiusVal)</l>
<l>    region_features (ConnectedRegions1, 'outer_radius', outer_radiusValue)</l>
<l>    OKorNG := 1</l>
<l>    try</l>
<l>        if (max(AreaValue)&gt;MaxAreaVal               or \
            sum(AreaValue)&gt;SumAreaVal               or \
            max(outer_radiusValue)&gt;outer_radiusVal or \
            |AreaValue|-1&gt;NumVal)</l>
<c></c>
<l>            OKorNG := 0</l>
<l>        endif</l>
<l>    catch (Exception)</l>
<l>        AreaValue := 0</l>
<l>        outer_radiusValue:=0</l>
<l>    endtry</l>
<l>    Set_Quality_Dll (Image, SelectedRegions, IDTime, OKorNG, ['个数','最大面积','总面积','最大长度'], [|AreaValue|-1,max(AreaValue),sum(AreaValue),max(outer_radiusValue)], Quality_2)</l>
<l>    set_dict_tuple (AllQualitys, XidiName[xidiIndex]+Grade, Quality)</l>
<l>endfor</l>
<l>return ()</l>
</body>
<docu id="analyse_Shape_Class_Dll">
<parameters>
<parameter id="AllQualitys"/>
<parameter id="G_ParmDict"/>
<parameter id="Grade"/>
<parameter id="IDTime"/>
<parameter id="Image"/>
<parameter id="RegionDictHandle"/>
</parameters>
</docu>
</procedure>
<procedure name="Set_Quality_Dll">
<interface>
<io>
<par name="Image" base_type="iconic" dimension="0"/>
<par name="SelectedRegions" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="TimeID" base_type="ctrl" dimension="0"/>
<par name="OKorNG" base_type="ctrl" dimension="0"/>
<par name="Names" base_type="ctrl" dimension="0"/>
<par name="Vals" base_type="ctrl" dimension="0"/>
<par name="Quality" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<c></c>
<l>*create_dict (Quality)</l>
<l>set_dict_tuple (Quality, '质量', OKorNG)</l>
<l>try</l>
<l>    region_features (SelectedRegions, 'area', area)</l>
<l>    create_dict (AllRegionDict)</l>
<l>    if(area!=0)</l>
<l>        connection (SelectedRegions, ConnectedRegions)</l>
<l>        count_obj (ConnectedRegions, Number)</l>
<l>        for n:=1 to Number by 1</l>
<l>            create_dict (RegionDict)</l>
<l>            select_obj (ConnectedRegions, ObjectSelected, n)</l>
<l>            region_features (ObjectSelected, ['row','column','outer_radius'], Value)</l>
<l>            set_dict_tuple (RegionDict, 'Y', Value[0])</l>
<l>            set_dict_tuple (RegionDict, 'X', Value[1])</l>
<l>            set_dict_tuple (RegionDict, 'R', Value[2])</l>
<l>            set_dict_tuple (AllRegionDict, 'Region'+n, RegionDict)</l>
<l>        endfor</l>
<l>    else</l>
<c>        </c>
<c>       </c>
<l>    endif</l>
<l>catch (Exception)</l>
<c>    </c>
<l>endtry</l>
<c></c>
<l>for Index := 0 to |Names|-1 by 1</l>
<l>    set_dict_tuple (Quality, Names[Index], Vals[Index])</l>
<l>endfor</l>
<l>*     set_dict_tuple (Quality, 'AllRegion', AllRegionDict)</l>
<c></c>
<l>return ()</l>
</body>
