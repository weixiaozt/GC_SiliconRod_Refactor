<procedure name="LoadParams">
<interface>
<ic>
<par name="Parmsetting" base_type="ctrl" dimension="0"/>
<par name="level" base_type="ctrl" dimension="0"/>
<par name="n" base_type="ctrl" dimension="0"/>
<par name="DefaultValue" base_type="ctrl" dimension="0"/>
<par name="Competence" base_type="ctrl" dimension="0"/>
<par name="Type" base_type="ctrl" dimension="0"/>
<par name="Limit" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="Value" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>global tuple G_ParmDict</l>
<c></c>
<c></c>
<l>if (n&lt;|level|)</l>
<l>    get_dict_param (Parmsetting, 'key_exists', level[n], IsModelDictExists)</l>
<l>    if (IsModelDictExists=0)</l>
<l>        create_dict (model)</l>
<l>        set_dict_tuple (Parmsetting, level[n], model)</l>
<l>        LoadParams (model, level, n+1, DefaultValue, Competence, Type, Limit, Value)</l>
<l>    else</l>
<l>        get_dict_tuple (Parmsetting, level[n], model)</l>
<l>        LoadParams (model, level, n+1, DefaultValue, Competence, Type, Limit, Value)</l>
<l>    endif</l>
<l>else</l>
<l>    get_dict_param (Parmsetting, 'key_exists', 'Value', IsModelDictExists)</l>
<c>    </c>
<l>    if (IsModelDictExists=0)</l>
<c>        </c>
<l>        set_dict_tuple (Parmsetting, 'Competence', Competence)</l>
<l>        set_dict_tuple (Parmsetting, 'Type', Type)</l>
<l>        set_dict_tuple (Parmsetting, 'Limit', Limit)</l>
<c>        *判断布尔类型********************************************************************</c>
<l>        if(Type='bool' )</l>
<l>            if( DefaultValue='FALSE' or DefaultValue='TRUE')</l>
<c>        </c>
<l>            else</l>
<l>                DefaultValue:='TRUE'</l>
<l>            endif</l>
<l>        endif</l>
<c>        *********************************************************************</c>
<l>        set_dict_tuple (Parmsetting, 'Value', DefaultValue)</l>
<l>        get_dict_tuple (Parmsetting, 'Value', Value)</l>
<l>    else</l>
<l>        get_dict_tuple (Parmsetting, 'Value', Value)</l>
<l>    endif</l>
<c>    *判断数组类型********************************************************************</c>
<l>    if(Type='int[]' or Type='float[]'or  Type= 'string[]')</l>
<c>        </c>
<l>        tuple_type (Value, ValueType)</l>
<l>        if(ValueType=4)</l>
<l>            tuple_split (Value, '[,]', Value)</l>
<l>            if(Type='int[]' or Type='float[]')</l>
<l>                tuple_number (Value, Value)</l>
<l>            endif</l>
<l>        elseif(ValueType=16)</l>
<l>            get_dict_param (Value, 'keys', [], GenParamValue)</l>
<l>            Values:=[]</l>
<l>            for Index := 0 to |GenParamValue|-1 by 1</l>
<l>                get_dict_tuple (Value, GenParamValue[Index], Tuple)</l>
<l>                Values:=[Values,Tuple]</l>
<l>            endfor</l>
<l>           Value:=Values</l>
<l>        endif</l>
<c></c>
<l>    endif</l>
<c>    *********************************************************************</c>
<c></c>
<c>    </c>
<l>endif</l>
<c></c>
<l>return ()</l>
</body>
<docu id="LoadParams">
<parameters>
<parameter id="Competence">
<default_type>integer</default_type>
<default_value>1</default_value>
<description lang="zh_CN">管理权限，这个权限有三级，”操作员”（1），”工程师”（2），”厂商”（3）,拥有不同密码，密码在config文件下明码修改，输入对应密码后显示对应参数。</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<sem_type>integer</sem_type>
<type_list>
<item>integer</item>
</type_list>
<value_list>
<item>1</item>
<item>2</item>
<item>3</item>
</value_list>
<value_max>3</value_max>
<value_min>1</value_min>
</parameter>
<parameter id="DefaultValue">
<description lang="zh_CN">没有参数时输出的默认值</description>
<sem_type>any</sem_type>
</parameter>
<parameter id="Limit">
<description lang="zh_CN">参数限制，在参数类型是数字类时做大小限制的限制，是一个数组，第 一位最小值，第二位是最大值，参数类型是枚举时该参数为被枚举所有元 素</description>
<multivalue>optional</multivalue>
<sem_type>any</sem_type>
</parameter>
<parameter id="Parmsetting">
<mixed_type>false</mixed_type>
<sem_type>dict</sem_type>
<type_list>
<item>integer</item>
</type_list>
</parameter>
<parameter id="Type">
<default_type>string</default_type>
<default_value>int</default_value>
<description lang="zh_CN">当你解析好界面上的参数["Value"]以什么数据类型 输出，详见附录“数据类型与控件对应”</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
<value_list>
<item>'int'</item>
<item>'float'</item>
<item>'bool'</item>
<item>'int[]'</item>
<item>'float[]'</item>
<item>'string'</item>
<item>'string[]'</item>
<item>'string_enum'</item>
<item>'int_enum'</item>
<item>'float_enum'</item>
<item>'path'</item>
<item>'directory'</item>
</value_list>
</parameter>
<parameter id="Value"/>
<parameter id="level">
<default_type>string</default_type>
<default_value>['检测参数','隐裂','面积筛子']</default_value>
<description lang="zh_CN">多级目录，数组表示只能用字符串数组</description>
<mixed_type>false</mixed_type>
<multivalue>optional</multivalue>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
</parameter>
<parameter id="n">
<default_type>integer</default_type>
<default_value>0</default_value>
<description lang="zh_CN">递归参数，不可变只能0</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<sem_type>integer</sem_type>
<type_list>
<item>integer</item>
</type_list>
<value_list>
<item>0</item>
</value_list>
</parameter>
</parameters>
</docu>
</procedure>
<procedure name="YouEyE_OpenWindows">
<interface>
<ic>
<par name="width" base_type="ctrl" dimension="0"/>
<par name="height" base_type="ctrl" dimension="0"/>
<par name="Mode" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="WindowHandle" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<c>    </c>
<c></c>
<l>open_window (0, 0, width, height, 0, Mode, '', WindowHandle)</l>
<l>set_line_width (WindowHandle, int(max([width,height])*0.003))</l>
<l>set_draw (WindowHandle, 'margin')</l>
<l>return ()</l>
</body>
