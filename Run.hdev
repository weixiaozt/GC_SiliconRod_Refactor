<procedure name="Engine">
<interface>
<ic>
<par name="DBIndex" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>global tuple QuitTaskFlag</l>
<l>global tuple G_RunEngine</l>
<l>global tuple G_ParmDict</l>
<l>QuitTaskFlag := 0</l>
<l>create_dict (G_RunEngine)</l>
<l>create_dict (G_ParmDict)</l>
<l>create_mutex ([], [], G_ParmDictMutex)</l>
<l>set_dict_tuple (G_RunEngine, 'G_ParmDictMutex', G_ParmDictMutex)</l>
<c></c>
<c></c>
<c>* *************//日志//*******************************************************************</c>
<l>par_start&lt;LogThread&gt; : LogThread ()</l>
<l>wait_seconds (0.5)</l>
<c>* *******************************//Redis发布线程//*************************************************</c>
<l>par_start&lt;RedisThread&gt; : RedisThread (DBIndex)</l>
<c>* *******************************//mysql数据库//********************************************</c>
<l>wait_seconds (3)</l>
<l>EnQueueLog ('Log', '引擎启动', ' ', ' ')</l>
<c></c>
<l>return ()</l>
<l>if (1=0)</l>
<l>    gen_empty_obj (Image)</l>
<l>CreateID (IDTime)</l>
<l>EnQueueLog ('日志文件名', '类型名', '项目名', '值')</l>
<l>EnQueueRedisImage (Image, '放json')</l>
<l>SaveImage_COPY_1 (Image, '路径', '图像格式', 'ID号', '通信ID', FileNameSQL)</l>
<l>YouEyE_OpenWindows_COPY_1 (224, 300, '', MainImageWindowHandle)</l>
<l>YouEyE_DispImage (Image, MainImageWindowHandle, '')</l>
<l>LogException_COPY_1 (Exception, Exception)</l>
<c></c>
<l>endif</l>
</body>
<docu id="Engine">
<parameters>
<parameter id="DBIndex"/>
</parameters>
</docu>
</procedure>
<procedure name="YouEyE_OpenWindows_COPY_1">
<interface>
