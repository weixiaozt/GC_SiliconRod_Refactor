<procedure name="CreateID">
<interface>
<oc>
<par name="IDTime" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>get_system_time (MSecond, Second, Minute, Hour, Day, YDay, Month, Year)</l>
<l>IDTime := Year*10000000000000+Month*100000000000+Day*1000000000+Hour*10000000+Minute*100000+Second*1000+MSecond</l>
<l>EnQueueLog_COPY_1 ('Check', '头节点', '生成IDTime', IDTime)</l>
<c></c>
<l>return ()</l>
</body>
