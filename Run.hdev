<procedure name="Init_HalconClass">
<interface>
<ic>
<par name="Name" base_type="ctrl" dimension="0"/>
<par name="G_ParmDict" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="DictHandle" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<c></c>
<l>try</l>
<c></c>
<l>    read_dict ('./algorithm/'+Name+'_dl_preprocess_params.hdict', [], [], DLPreprocessParam)</l>
<l>    read_dl_model ('./algorithm/'+Name+'.hdl', DLModelHandle)</l>
<l>    LoadParam (G_ParmDict, 'AI', '硬件设置', '计算设备', 'cpu', 3, 'string_enum', ['cpu','gpu'], DeviceTypeClass)</l>
<c></c>
<l>    query_available_dl_devices (['runtime'], [DeviceTypeClass], DLDeviceHandles)</l>
<l>    if (|DLDeviceHandles| == 0)</l>
<l>        DLPreprocessParam := 0</l>
<l>        DLModelHandle := 0</l>
<l>    else</l>
<c>        * Due to the filter used in query_available_dl_devices, the first device is a GPU, if available.</c>
<l>        DLDevice := DLDeviceHandles[0]</l>
<l>        set_dl_model_param (DLModelHandle, 'device', DLDevice)</l>
<l>        set_dl_model_param (DLModelHandle, 'batch_size', 1)</l>
<l>    endif</l>
<c></c>
<c></c>
<l>catch (Exception)</l>
<l>    LogException (Exception, Ex)</l>
<l>    Log ('Exception', Exception)</l>
<l>    DLPreprocessParam := 0</l>
<l>    DLModelHandle := 0</l>
<l>endtry</l>
<l>create_dict (DictHandle)</l>
<l>set_dict_tuple (DictHandle, '权重', DLModelHandle)</l>
<l>set_dict_tuple (DictHandle, '配置', DLPreprocessParam)</l>
<l>LoadParam (G_ParmDict, 'AI', '软件设置', '分类尺寸', 64, 3, 'int', [15,65], MAX_SIZE)</l>
<l>set_dict_tuple (DictHandle, '分类尺寸', MAX_SIZE)</l>
<c></c>
<c></c>
<l>return ()</l>
</body>
<docu id="Init_HalconClass">
<parameters>
<parameter id="DictHandle"/>
<parameter id="G_ParmDict"/>
<parameter id="Name"/>
</parameters>
</docu>
</procedure>
<procedure name="Run">
<interface>
<ic>
<par name="DBIndex" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<c></c>
<c>* *******退出标志**************</c>
<l>global tuple QuitTaskFlag</l>
<c>* *******引擎用全局变量容器****</c>
<l>global tuple G_RunEngine</l>
<c>* *******参数变量容器**********</c>
<l>global tuple G_ParmDict</l>
<c>* *******引擎函数**************</c>
<c></c>
<c></c>
<l>create_dict (ParmDict)</l>
<c></c>
<l>dict_to_json (ParmDict, [], [], ParmDict)</l>
<c></c>
<c></c>
<c></c>
<l>Init_Xkk (DictHandle, DictHandle1)</l>
<c></c>
<c></c>
<c></c>
<l>Detection_init (ParmDict, ResourceDictHandle, ParmDict, Exception)</l>
<l>dev_update_off ()</l>
<l>Engine (DBIndex)</l>
<l>XC := 1</l>
<l>Init_Camera_Modbus_Check (DiameterObject, QueueHandle, Handle)</l>
<l>* IDTime:=1</l>
<c></c>
<l>*Init_Yolo (DictHandle, ModelHandle)</l>
<c>* ==================== 2. 打开TCP连接 ====================</c>
<c></c>
<l>Code_Tcp (ReaderIP, SocketHandle, CQueueHandle)</l>
<l>* send_data (SocketHandle, 'z', 'start',[ReaderIP,5000])</l>
<l>while (QuitTaskFlag=0)</l>
<c>    </c>
<c>    </c>
<l>    wait_seconds (2)</l>
<l>     BVCAM_FeatureCommand (Handle, 'TriggerSoftware')</l>
<l>    try</l>
<c>        </c>
<l>        BV_GrapImage (Image1, Image, QueueHandle, Handle)</l>
<l>        DEImage (Image, Image2, Image3, Image4)</l>
<l>         zoom_image_factor (Image, ImageZoomed, 1, 0.333, 'constant')</l>
<l>        Median_Tuple (DiameterObject, Image, Value)</l>
<c>        </c>
<c>        </c>
<l>               threshold (ImageZoomed, Regions, Value+0.3*Value, 65535)</l>
<l>        paint_region (Regions, ImageZoomed, ImageResult, Value+0.3*Value, 'fill')</l>
<l>        scale_image_max (ImageResult, ImageScaleMax)</l>
<l>        CreateID (IDTime)</l>
<l>*         ht (Image, Image, Image2)</l>
<l>        try</l>
<l>            dequeue_message (CQueueHandle, 'timeout', 1, MessageHandle)</l>
<l>            get_message_tuple (MessageHandle, '晶编', CHAR)</l>
<l>            while (1)</l>
<l>                try</l>
<l>                    dequeue_message (CQueueHandle, 'timeout', 1, MessageHandle)</l>
<l>                    get_message_tuple (MessageHandle, '晶编', CHAR)</l>
<l>                catch (Exception)</l>
<l>                    break</l>
<l>                endtry</l>
<l>            endwhile</l>
<l>*             send_data (SocketHandle, 'z', 'start',[ReaderIP,5000])</l>
<l>        catch (Exception)</l>
<l>            CHAR:='NoRead'</l>
<l>        endtry</l>
<c>        </c>
<l>        rotate_image (ImageScaleMax, ImageRotate, 90, 'constant')</l>
<l>        zoom_image_size (ImageRotate, ImageZoom, 3072, 1024, 'constant')</l>
<l>        try</l>
<l>            write_image (Image, 'tiff', 0, 'D:/SiRod/ImageRaw/'+IDTime+'_'+CHAR)</l>
<c>            </c>
<l>        catch (Exception)</l>
<l>        endtry</l>
<c>        </c>
<l>        try</l>
<l>            SaveImage (ImageZoom, 'D:/SiRod/训练图/'+CHAR+'_', 'bmp', IDTime)</l>
<l>        catch (Exception)</l>
<l>        endtry</l>
<l>        count_seconds (Seconds)</l>
<l>        Detection_process (ImageZoom, SaveImage, DispImage, SelectedRegions, IDTime, ParmDict, DictHandle, DictHandle1, CHAR, AllQuality, OutParmDict, Exception)</l>
<l>        count_seconds (Seconds1) </l>
<l>         EnQueueLog ('log', 'info', '检测完成', Seconds1-Seconds)</l>
<l>        CT:=Seconds1-Seconds</l>
<l>        get_dict_tuple (AllQuality, '质量', Tuple)</l>
<c>        </c>
<l>        set_dict_tuple (AllQuality, '检测时长', CT)</l>
<l>        get_system_time (MSecond, Second, Minute, Hour, Day, YDay, Month, Year)</l>
<l>        DT:=Year+'年'+Month+'月'+Day+'日'+Hour+'时'+Minute+'分'+Second+'秒'+MSecond</l>
<l>        set_dict_tuple (AllQuality, '检测时间', DT)</l>
<l>        set_dict_tuple (AllQuality, '隐裂长度', 1)</l>
<c>        </c>
<l>        Craete_DISPImage (ImageZoom, SelectedRegions, ImageDUMP)</l>
<l>        if (Tuple=1)</l>
<l>            get_system_time (MSecond1, Second1, Minute1, Hour1, Day1, YDay1, Month1, Year1)</l>
<l>            path:=CHAR+'_'+Year1+Month1+Day1+Hour1+Minute1+Second1</l>
<l>            zoom_image_size (ImageDUMP, ImageZoomf, 1920, 640, 'constant')</l>
<l>            scale_image_max (ImageZoomf, ImageScaleMax1)</l>
<l>            convert_image_type (ImageScaleMax1, ImageConverted, 'byte')</l>
<l>            rotate_image (ImageConverted, ImageRotate1, 180, 'constant')</l>
<l>            write_image (ImageRotate1, 'png', 0, 'D:/SiRod/WebImage/'+path)</l>
<l>            set_dict_tuple (AllQuality, '图片路径', 'http://10.32.50.220:8080/'+path+'.png')</l>
<l>        endif</l>
<l>        dict_to_json (AllQuality, [], [], JsonString)</l>
<l>        rotate_image (ImageDUMP, ImageDUMP, -180, 'constant')</l>
<l>        mirror_image (ImageDUMP, ImageDUMP, 'column')</l>
<l>        EnQueueRedisImage (ImageDUMP, JsonString)</l>
<c>        </c>
<c>        </c>
<l>    catch (Exception)</l>
<l>    endtry</l>
<c>    </c>
<c>    </c>
<c>    </c>
<l>endwhile</l>
<l>close_socket (SocketHandle)</l>
<c></c>
<c></c>
<c></c>
<c></c>
<c></c>
<l>return ()</l>
</body>
<docu id="Run">
<parameters>
<parameter id="DBIndex"/>
</parameters>
</docu>
</procedure>
<procedure name="Find_CrystalWires">
<interface>
<io>
<par name="EmptyObject" base_type="iconic" dimension="0"/>
</io>
<oo>
<par name="EmptyObjectOut" base_type="iconic" dimension="0"/>
</oo>
<ic>
<par name="NP_Type" base_type="ctrl" dimension="0"/>
<par name="Diameter_Tuple" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="JT" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<c></c>
<l>global tuple QuitTaskFlag</l>
<l>EmptyObjectOut := EmptyObject</l>
<l>count_seconds (Seconds)</l>
<l>while (QuitTaskFlag=0)</l>
<l>    try</l>
<l>Read_JT (JT)</l>
<l>        count_seconds (Seconds1)</l>
<l>        if ((Seconds1-Seconds)&gt;30)</l>
<l>            break</l>
<l>        endif</l>
<l>        if (JT=2)</l>
<l>            return ()</l>
<l>        endif</l>
<l>Hik_grab_image ()</l>
<c></c>
<c></c>
<c></c>
<c></c>
<l>        gen_rectangle1 (ROI_0, 1500, 1557.95, 1700, 2785.31)</l>
<l>        reduce_domain (TakePhoto, ROI_0, ImageReduced)</l>
<l>*         crop_part (TakePhoto, ImagePart, 0, 256-128, 256, 256)</l>
<l>        threshold (ImageReduced, Regions, 40, 255)</l>
<l>        erosion_rectangle1 (Regions, RegionErosion, 300, 100)</l>
<l>*         dilation_rectangle1 (RegionErosion, RegionDilation, 1, 100)</l>
<l>        region_features (RegionErosion, 'area', Value)</l>
<l>        concat_obj (EmptyObjectOut, TakePhoto, EmptyObjectOut)</l>
<l>        if (Value&gt;10000)</l>
<c></c>
<l>            if (NP_Type='N')</l>
<l>                if (Diameter_Tuple&gt;270)</l>
<l>                    wait_seconds (1.7)</l>
<l>                else</l>
<l>                    wait_seconds (0.7)</l>
<c></c>
<l>                endif</l>
<l>            else</l>
<l>                wait_seconds (1)</l>
<c></c>
<l>            endif</l>
<l>            break</l>
<c></c>
<l>        endif</l>
<c></c>
<l>    catch (Exception)</l>
<l>    endtry</l>
<l>endwhile</l>
<l>try</l>
<l>    write_object (EmptyObjectOut, 'D:/jx123')</l>
<l>catch (Exception)</l>
<l>endtry</l>
<l>return ()</l>
</body>
<docu id="Find_CrystalWires">
<parameters>
<parameter id="Diameter_Tuple"/>
<parameter id="EmptyObject"/>
<parameter id="EmptyObjectOut"/>
<parameter id="JT"/>
<parameter id="NP_Type"/>
</parameters>
</docu>
</procedure>
<procedure name="Read_Modbus">
<interface>
<ic>
<par name="Type" base_type="ctrl" dimension="0"/>
<par name="address" base_type="ctrl" dimension="0"/>
<par name="Number" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="Tuple" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>create_dict (DictHandle)</l>
<l>try</l>
<c></c>
<l>    Tuple := []</l>
<c></c>
<l>    if (Type='int')</l>
<l>        modbus_read_registers (0, address, Number, DictHandle)</l>
<l>        for Index := 0 to Number-1 by 1</l>
<l>            get_dict_tuple (DictHandle, address+Index, Tuple1)</l>
<l>            Tuple := [Tuple,Tuple1]</l>
<l>        endfor</l>
<l>    elseif (Type='bool')</l>
<l>        modbus_read_bits (0, address, Number, DictHandle)</l>
<l>        get_dict_tuple (DictHandle, address, Tuple1)</l>
<l>        Tuple := Tuple1</l>
<l>    elseif (Type='float')</l>
<l>        modbus_read_registers (0, address, Number, DictHandle)</l>
<l>        for Index := 0 to Number-1 by 1</l>
<l>            get_dict_tuple (DictHandle, address+Index, Tuple1)</l>
<l>            Tuple := [Tuple,Tuple1]</l>
<l>        endfor</l>
<l>int_to_float ()</l>
<l>        get_dict_tuple (DictHandle, '转换结果', Tuple)</l>
<l>    endif</l>
<c></c>
<l>catch (Exception)</l>
<l>     modbus_tcp_connect (0,'132.16.10.186', 502)</l>
<l>    modbus_set_slave_ID (0, 1)</l>
<l>endtry</l>
<l>return ()</l>
</body>
<docu id="Read_Modbus">
<parameters>
<parameter id="Number"/>
<parameter id="Tuple"/>
<parameter id="Type">
<default_value>'int'</default_value>
<value_list>
<item>'bool'</item>
</value_list>
</parameter>
<parameter id="address"/>
</parameters>
</docu>
</procedure>
<procedure name="EnQueueLog">
<interface>
<ic>
<par name="Catlog" base_type="ctrl" dimension="0"/>
<par name="Meta" base_type="ctrl" dimension="0"/>
<par name="Tags" base_type="ctrl" dimension="0"/>
<par name="Values" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>global def tuple G_RunEngine</l>
<l>get_dict_tuple (G_RunEngine, 'G_Log_Queue', G_Log_Queue)</l>
<l>* get_dict_tuple (G_RunEngine, 'G_Log_QueueEvent', G_Log_QueueEvent)</l>
<c></c>
<l>try</l>
<l>    get_system_time (MSecond, Second, Minute, Hour, Day, YDay, Month, Year)</l>
<l>    Time := YDay+'.'+Hour+':'+Minute+':'+Second+'.'+MSecond</l>
<l>    create_message (MessageLog)</l>
<l>    set_message_tuple (MessageLog, 'Catlog', Catlog+'.txt')</l>
<l>    set_message_tuple (MessageLog, 'Time', Time)</l>
<l>    set_message_tuple (MessageLog, 'Meta', Meta)</l>
<l>    set_message_tuple (MessageLog, 'Tags', Tags)</l>
<l>    set_message_tuple (MessageLog, 'Values', Values)</l>
<l>    enqueue_message (G_Log_Queue, MessageLog, [], [])</l>
<l>    clear_message (MessageLog)</l>
<l>*     signal_event (G_Log_QueueEvent)</l>
<l>catch (Exception)</l>
<l>endtry</l>
<l>return ()</l>
</body>
<docu id="EnQueueLog">
<abstract lang="zh_CN">日志记录函数</abstract>
<parameters>
<parameter id="Catlog">
<default_type>string</default_type>
<default_value>'check'</default_value>
<description lang="zh_CN">日志文件名</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
<values>
<item>'check'</item>
<item>'Exception'</item>
<item>'TCP'</item>
<item>'Engine'</item>
</values>
</parameter>
<parameter id="Meta">
<default_type>string</default_type>
<default_value>类名</default_value>
<description lang="zh_CN">属于哪种类型的日志</description>
<mixed_type>false</mixed_type>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
</parameter>
<parameter id="Tags">
<description lang="zh_CN">项目名，记录的这条日志的项目名称</description>
</parameter>
<parameter id="Values">
<description lang="zh_CN">值，这条日志的对应的项目的值</description>
</parameter>
</parameters>
</docu>
</procedure>
<procedure name="dev_update_off">
<interface/>
<body>
<c>* This procedure sets different update settings to 'off'.</c>
<c>* This is useful to get the best performance and reduce overhead.</c>
<c></c>
<l>dev_update_pc ('off')</l>
<l>dev_update_var ('off')</l>
<l>dev_update_window ('off')</l>
<l>return ()</l>
</body>
<docu id="dev_update_off">
<abstract lang="en_US">This procedure sets dev_update_pc, dev_update_var and dev_update_window to 'off'.</abstract>
<alternatives>
<item>dev_update_pc</item>
<item>dev_update_var</item>
<item>dev_update_window</item>
</alternatives>
<chapters lang="de_DE">
<item>Develop</item>
</chapters>
<chapters lang="en_US">
<item>Develop</item>
</chapters>
<example lang="en_US">dev_update_off ()
* do something
dev_update_on ()</example>
<keywords lang="de_DE">
<item>Aktualisierungsmodus setzen</item>
</keywords>
<keywords lang="en_US">
<item>set update mode</item>
</keywords>
<library lang="de_DE">MVTec Standard Procedures</library>
<library lang="en_US">MVTec Standard Procedures</library>
<see_also>
<item>dev_update_on</item>
</see_also>
<short lang="de_DE">Switch dev_update_pc, dev_update_var and dev_update_window to 'off'.</short>
<short lang="en_US">Switch dev_update_pc, dev_update_var and dev_update_window to 'off'.</short>
<parameters/>
</docu>
</procedure>
<procedure name="EnQueueRedisImage">
