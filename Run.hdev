<io>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="Json" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>global tuple G_RunEngine</l>
<l>get_dict_tuple (G_RunEngine, 'G_Redis_Queue', G_Redis_Queue)</l>
<l>create_message (MessageRedis)</l>
<l>SetStringByImageIn (Imagestr, Json)</l>
<l>concat_obj (Imagestr, Image, MultiChannelImage)</l>
<l>set_message_obj (Image, MessageRedis, 'ChannelData')</l>
<l>set_message_tuple (MessageRedis, 'tuple', Json)</l>
<l>enqueue_message (G_Redis_Queue, MessageRedis, [], [])</l>
