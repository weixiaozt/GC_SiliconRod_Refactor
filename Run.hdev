<item>0</item>
<item>1</item>
</value_list>
<value_max>1</value_max>
</parameter>
<parameter id="x">
<sem_type>image</sem_type>
<type_list>
<item>real</item>
</type_list>
</parameter>
<parameter id="y">
<sem_type>image</sem_type>
<type_list>
<item>real</item>
</type_list>
</parameter>
<parameter id="z">
