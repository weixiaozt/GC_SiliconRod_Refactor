<procedure name="Detection_process">
<interface>
<io>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<oo>
<par name="SaveImage" base_type="iconic" dimension="0"/>
<par name="DispImage" base_type="iconic" dimension="0"/>
<par name="SelectedRegions" base_type="iconic" dimension="0"/>
</oo>
<ic>
<par name="IDTime" base_type="ctrl" dimension="0"/>
<par name="ParmDict" base_type="ctrl" dimension="0"/>
<par name="DictHandle" base_type="ctrl" dimension="0"/>
<par name="DictHandle1" base_type="ctrl" dimension="0"/>
<par name="CHAR" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="AllQualitys" base_type="ctrl" dimension="0"/>
<par name="OutParmDict" base_type="ctrl" dimension="0"/>
<par name="Ex" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>try</l>
<c>    </c>
<l>    Ex:=[]</l>
<l>    json_to_dict (ParmDict, [], [], G_ParmDict)</l>
<c>    </c>
<l>    create_dict (AllQualitys)</l>
<l>    set_dict_tuple (AllQualitys, 'ID', IDTime)//准备好ID</l>
<l>    set_dict_tuple (AllQualitys, '晶编', CHAR)//准备好ID</l>
<c>    **********准备检测************</c>
<l>    create_dict (RegionDict)</l>
<l>    gen_empty_obj (EmptyObject)</l>
<c>    </c>
<l>    set_dict_object(EmptyObject,RegionDict, '崩边')</l>
<l>    set_dict_object(EmptyObject,RegionDict, '隐裂')//刷新所有region</l>
<c>    *************检测开始*****************************************************************************************************</c>
<c>    </c>
<c>    *****隐裂：</c>
<l>*     scale_image_max (Image, ImageScaleMax)</l>
<l>*     convert_image_type (ImageScaleMax, ImageConverted, 'byte')</l>
<l>    *rotate_image (Image, Image, 180, 'constant')</l>
<l>    set_dict_object (Image, DictHandle, '输入图')</l>
<l>    DnnInfer_Seg_Infer (outimage, DictHandle)</l>
<c>    </c>
<c>    </c>
<l>*     gen_empty_obj (EmptyObject)</l>
<l>*     set_dict_object (EmptyObject, DictHandle, 'ClassLabelImage')</l>
<l>*     set_dict_object (EmptyObject, DictHandle, 'BoundingBoxes')</l>
<c>    </c>
<l>*     yolo_seg_detect (ModelHandle, DictHandle)</l>
<c>    </c>
<l>*     get_dict_object (binImage, DictHandle, 'ClassLabelImage')</l>
<l>*     get_dict_object (BOX, DictHandle, 'BoundingBoxes')</l>
<c>    </c>
<c>    </c>
<l>    threshold (outimage, Regions, 1, 3)</l>
<c>    </c>
<l>    *Roi (Image, RegionDifference1)</l>
<c>    </c>
<l>    gen_rectangle1 (RegionDifference1, -147.17, 7.54188, 93.99, 3106.35)</l>
<c>    </c>
<l>    difference (Regions, RegionDifference1, Regions)</l>
<c></c>
<l>    connection (Regions, ConnectedRegions)</l>
<l>    select_shape (ConnectedRegions, SelectedRegions1, 'outer_radius', 'and', 5, 99999)</l>
<c>    </c>
<l>    AreaVal:=100</l>
<l>    select_shape (SelectedRegions1, SelectedRegions, 'area', 'and', AreaVal, 25000000)</l>
<l>    union1 (SelectedRegions, RegionUnion)</l>
<l>    connection (RegionUnion, ConnectedRegions1)</l>
<l>    region_features (ConnectedRegions1, 'area', AreaValue)</l>
<l>    LoadParam (G_ParmDict, '检测参数', '', '允许最大面积', 10, 1, 'int', [0,25000000], MaxAreaVal)</l>
<l>    LoadParam (G_ParmDict, '检测参数', '', '允许总面积', 10, 1, 'int', [0,25000000], SumAreaVal)</l>
<l>    LoadParam (G_ParmDict, '检测参数', '', '允许个数', 10, 1, 'int', [0,25000000], NumVal)</l>
<l>    LoadParam (G_ParmDict, '检测参数', '', '允许最大长度', 2, 1, 'int', [0,25000000], outer_radiusVal)</l>
<l>    region_features (ConnectedRegions1, 'outer_radius', outer_radiusValue)</l>
<l>    OKorNG := 0</l>
<l>    set_dict_tuple (AllQualitys, '类型', 'OK')</l>
<c>    </c>
<c>    </c>
<l>    try</l>
<l>        if (max(AreaValue)&gt;MaxAreaVal               or \
            sum(AreaValue)&gt;SumAreaVal               or \
            max(outer_radiusValue)&gt;outer_radiusVal or \
            |AreaValue|-1&gt;NumVal)</l>
<c>            </c>
<c>            </c>
<l>            count_obj (ConnectedRegions1, Number)</l>
<l>            for Index := 1 to Number by 1</l>
<l>                select_obj (ConnectedRegions1, ObjectSelected, Index)</l>
<l>                dilation_rectangle1 (ObjectSelected, RegionDilation, 50, 50)</l>
<l>                shape_trans (RegionDilation, RegionTrans, 'rectangle1')</l>
<l>                reduce_domain (Image, RegionTrans, ImageReduced)</l>
<l>                crop_domain (ImageReduced, ImagePart)</l>
<l>                try</l>
<c>                    </c>
<l>                    write_image (ImagePart, 'bmp', 0, 'D:/SiRod/CropImage/'+CHAR+'_'+IDTime)</l>
<c>                    </c>
<l>                catch (Exception)</l>
<l>                endtry</l>
<l>                set_dict_object (ImagePart, DictHandle1, '输入图')</l>
<c>                </c>
<l>                DnnInfer_Seg_Infer (outimage, DictHandle1)</l>
<l>                get_dict_tuple (DictHandle1, '类别', Tuple)</l>
<l>                try</l>
<l>                    SaveImage (ImagePart, 'D:/SiRod/Class/'+Tuple+'/'+CHAR+'_', 'bmp', IDTime)</l>
<l>                catch (Exception)</l>
<l>                endtry</l>
<l>                if (Tuple='隐裂')</l>
<l>                    OKorNG := 1</l>
<l>region_features (RegionTrans, 'outer_radius', Value)</l>
<l>                    set_dict_tuple (AllQualitys, '类型', '隐裂')</l>
<l>                     set_dict_tuple (AllQualitys, '长度', Value)</l>
<l>                endif</l>
<c>                </c>
<l>            endfor</l>
<c>            </c>
<c>            </c>
<l>        endif</l>
<l>    catch (Exception)</l>
<l>        AreaValue := 0</l>
<l>        outer_radiusValue:=0</l>
<l>    endtry</l>
<l>*     OKorNG :=1</l>
<l>*     set_dict_tuple (AllQualitys, '类型', '隐裂')</l>
<l>    Set_Quality_Dll (Image, SelectedRegions, IDTime, OKorNG, ['个数','最大面积','总面积','最大长度'], [|AreaValue|-1,max(AreaValue),sum(AreaValue),max(outer_radiusValue)], AllQualitys)</l>
<c>    </c>
<l>    SaveImage:=Image</l>
<l>    DispImage:=SaveImage</l>
<c>    </c>
<l>catch (Exception)</l>
<l>    LogException (Exception, Ex)</l>
<c>    </c>
<l>endtry</l>
<l>dict_to_json ( G_ParmDict, [], [],OutParmDict)</l>
<l>return ()</l>
</body>
<docu id="Detection_process">
<parameters>
<parameter id="AllQualitys"/>
<parameter id="CHAR"/>
<parameter id="DictHandle"/>
<parameter id="DictHandle1"/>
<parameter id="DispImage"/>
<parameter id="Ex"/>
<parameter id="IDTime"/>
<parameter id="Image"/>
<parameter id="OutParmDict"/>
<parameter id="ParmDict"/>
<parameter id="SaveImage"/>
<parameter id="SelectedRegions"/>
</parameters>
</docu>
</procedure>
<procedure name="Detection_init">
<interface>
