<procedure name="ZJYC_FZ">
<interface>
<oc>
<par name="YD" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>global tuple QuitTaskFlag</l>
<l>modbus_write_bit (0, 1002, 0)</l>
<l>modbus_write_bit (0, 212, 1)</l>
<l>wait_seconds (1.9)</l>
<l>modbus_write_bit (0, 212, 0)</l>
<l>modbus_write_bit (0, 1002, 1)</l>
<l>EnQueueLog_COPY_1 ('Log', '刻线前调整角度', 212, 1)</l>
<l>while (QuitTaskFlag=0)</l>
<l>Read_Modbus ('bool', 126, 1, YD)</l>
<l>    modbus_write_bit (0, 176, 1)</l>
<l>    if (YD=0)</l>
<l>EnQueueLog_COPY_1 ('Log', '刻线前确认是否静止', 126, YD)</l>
<l>        break</l>
<l>    endif</l>
<l>endwhile</l>
<l>modbus_write_registerFloat ()</l>
<l>modbus_write_bit (0, 126, 1)</l>
<l>while (QuitTaskFlag=0)</l>
<l>Read_Modbus ('bool', 126, 1, YD)</l>
<l>    if (YD=0)</l>
<l>EnQueueLog_COPY_1 ('Log', '刻线前确认是否静止', 126, YD)</l>
<l>        break</l>
<l>    endif</l>
<l>endwhile</l>
<l>return ()</l>
</body>
<docu id="ZJYC_FZ">
<parameters>
<parameter id="YD"/>
</parameters>
</docu>
</procedure>
<procedure name="LJThread">
<interface>
<oo>
<par name="LJTakePhoto" base_type="iconic" dimension="0"/>
<par name="EmptyObject" base_type="iconic" dimension="0"/>
</oo>
<ic>
<par name="ID" base_type="ctrl" dimension="0"/>
<par name="LJCJ" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="Exception" base_type="ctrl" dimension="0"/>
<par name="LJKK" base_type="ctrl" dimension="0"/>
<par name="JT" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>gen_empty_obj (EmptyObject)</l>
<l>H := 0</l>
<c></c>
<l>count_seconds (Seconds)</l>
<l>while (1)</l>
<l>    count_seconds (Seconds1)</l>
<l>Read_JT (JT)</l>
<l>    if (JT=2)</l>
<l>        break</l>
<l>    endif</l>
<c></c>
<l>Read_Modbus ('bool', 128, 1, YD)</l>
<l>    if (YD=0)</l>
<l>EnQueueLog ('Log', '到达终点', 128, YD)</l>
<l>        break</l>
<l>    endif</l>
<c></c>
<l>    if ((Seconds1-Seconds)&gt;50)</l>
<l>        break</l>
<l>    endif</l>
<l>    try</l>
<c></c>
<l>Hik_grab_image ()</l>
<l>        H := H+1</l>
<l>        if (H&gt;190)</l>
<l>            break</l>
<l>        endif</l>
<c></c>
<l>            concat_obj (EmptyObject, LJTakePhoto, EmptyObject)</l>
<c></c>
<l>    catch (Exception)</l>
<c></c>
<c></c>
<l>    endtry</l>
<c></c>
<l>endwhile</l>
<l>Hik_stop_framegrabber ()</l>
<l>* modbus_write_bit (0, 177, 0)</l>
<l>* modbus_write_bit (0, 178, 0)</l>
<c></c>
<l>return ()</l>
</body>
<docu id="LJThread">
<parameters>
<parameter id="EmptyObject"/>
<parameter id="Exception"/>
<parameter id="ID"/>
<parameter id="JT"/>
<parameter id="LJCJ"/>
<parameter id="LJKK"/>
<parameter id="LJTakePhoto"/>
</parameters>
</docu>
</procedure>
<procedure name="LJ_Juge">
<interface>
<io>
<par name="LJObjectData" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="start" base_type="ctrl" dimension="0"/>
<par name="ende" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="LJ_Tuple" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>try</l>
<c></c>
<c></c>
<l>    count_obj (LJObjectData, Number)</l>
<l>    LJ_Tuple := -1</l>
<l>    if (Number=0)</l>
<l>        LJ_Tuple := -1</l>
<l>    else</l>
<l>        S := int(start/38)+17</l>
<l>        T := int(ende/38)+13</l>
<l>        tuple_min ([T,Number], Min)</l>
<l>        for Index := S to Min by 1</l>
<l>*             Index := 123</l>
<l>            select_obj (LJObjectData, ObjectSelected, Index)</l>
<l>            crop_part (ObjectSelected, ObjectSelected1, 0, 0, 5120, 3500-800)</l>
<l>            gen_empty_region (RegionTrans2)</l>
<l>* LJ_SF_COPY_1_COPY_1 (ObjectSelected, RegionTrans2, Index)</l>
<c></c>
<c></c>
<l>* LJ_BY_Aread (ObjectSelected1, RegionTrans2, Index)</l>
<c></c>
<l>LJAread_Measure (ObjectSelected, RegionTrans2)</l>
<l>            union1 (RegionTrans2, RegionUnion)</l>
<l>            region_features (RegionUnion, 'area', Value)</l>
<l>            if (Value&gt;0)</l>
<l>                LJ_Tuple := 2</l>
<l>                break</l>
<l>            endif</l>
<c></c>
<l>        endfor</l>
<c></c>
<l>    endif</l>
<l>catch (Exception)</l>
<l>    LJ_Tuple := -1</l>
<l>endtry</l>
<l>return ()</l>
</body>
<docu id="LJ_Juge">
<parameters>
<parameter id="LJObjectData"/>
<parameter id="LJ_Tuple"/>
<parameter id="ende"/>
<parameter id="start"/>
</parameters>
</docu>
</procedure>
<procedure name="LoadParam_COPY_1">
<interface>
<ic>
<par name="Model" base_type="ctrl" dimension="0"/>
<par name="Nodes" base_type="ctrl" dimension="0"/>
<par name="Leaf" base_type="ctrl" dimension="0"/>
<par name="DefaultValue" base_type="ctrl" dimension="0"/>
<par name="Competence" base_type="ctrl" dimension="0"/>
<par name="Type" base_type="ctrl" dimension="0"/>
<par name="Limit" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="Value" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>global tuple G_ParmDict</l>
<l>global tuple G_RunEngine</l>
<l>global tuple QuitTaskFlag</l>
<l>ParmSettingPath := 'ParmSetting.json'</l>
<l>get_dict_tuple (G_RunEngine, 'G_ParmDictMutex', G_ParmDictMutex)</l>
<l>lock_mutex (G_ParmDictMutex)</l>
<l>try</l>
<l>    get_dict_param (G_ParmDict, 'key_exists', Model, IsModelDictExists)</l>
<l>    if (IsModelDictExists=1)</l>
<l>        get_dict_tuple (G_ParmDict, Model, ModelDict)</l>
<l>        get_dict_param (ModelDict, 'key_exists', Nodes, IsNodesDictExists)</l>
<l>        if (IsNodesDictExists=1)</l>
<l>            get_dict_tuple (ModelDict, Nodes, NodesDict)</l>
<l>            get_dict_param (NodesDict, 'key_exists', Leaf, IsLeafDictExists)</l>
<l>            if (IsLeafDictExists=1)</l>
<l>                get_dict_tuple (NodesDict, Leaf, LeafDict)</l>
<l>                get_dict_tuple (LeafDict, 'Value', Value)</l>
<l>            else</l>
<l>Init_Leaf (NodesDict, Leaf, Competence, Type, Limit, DefaultValue, Value)</l>
<l>                write_dict (G_ParmDict, ParmSettingPath, 'file_type', 'json')</l>
<l>                tuple_type (DefaultValue, ValueType)</l>
<l>                if (ValueType=8)</l>
<l>EnQueueLog_COPY_1 ('错误', 'LoadParam函数错误', Model+'&gt;'+Nodes+'&gt;'+Leaf, Type)</l>
<l>                endif</l>
<l>                if (Type='int' or Type='int[]' or Type='int_enum')</l>
<l>                    if (ValueType!=1)</l>
<l>EnQueueLog_COPY_1 ('错误', 'LoadParam函数错误', Model+'&gt;'+Nodes+'&gt;'+Leaf, Type)</l>
<l>                    endif</l>
<l>                elseif (Type='float' or Type='float[]' or Type='float_enum')</l>
<l>                    if (ValueType!=2)</l>
<l>EnQueueLog_COPY_1 ('错误', 'LoadParam函数错误', Model+'&gt;'+Nodes+'&gt;'+Leaf, Type)</l>
<l>                    endif</l>
<l>                elseif (Type='string' or Type='string[]' or Type='string_enum')</l>
<l>                    if (ValueType!=4)</l>
<l>EnQueueLog_COPY_1 ('错误', 'LoadParam函数错误', Model+'&gt;'+Nodes+'&gt;'+Leaf, Type)</l>
<l>                    endif</l>
<l>                endif</l>
<l>            endif</l>
<l>        else</l>
<l>            create_dict (NodesDict)</l>
<l>Init_Leaf (NodesDict, Leaf, Competence, Type, Limit, DefaultValue, Value)</l>
<l>            set_dict_tuple (ModelDict, Nodes, NodesDict)</l>
<l>            tuple_type (DefaultValue, ValueType)</l>
<l>            if (ValueType=8)</l>
<l>EnQueueLog_COPY_1 ('错误', 'LoadParam函数错误', Model+'&gt;'+Nodes+'&gt;'+Leaf, Type)</l>
<l>            endif</l>
<l>            if (Type='int' or Type='int[]' or Type='int_enum')</l>
<l>                if (ValueType!=1)</l>
<l>EnQueueLog_COPY_1 ('错误', 'LoadParam函数错误', Model+'&gt;'+Nodes+'&gt;'+Leaf, Type)</l>
<l>                endif</l>
<l>            elseif (Type='float' or Type='float[]' or Type='float_enum')</l>
<l>                if (ValueType!=2)</l>
<l>EnQueueLog_COPY_1 ('错误', 'LoadParam函数错误', Model+'&gt;'+Nodes+'&gt;'+Leaf, Type)</l>
<l>                endif</l>
<l>            elseif (Type='string' or Type='string[]' or Type='string_enum')</l>
<l>                if (ValueType!=4)</l>
<l>EnQueueLog_COPY_1 ('错误', 'LoadParam函数错误', Model+'&gt;'+Nodes+'&gt;'+Leaf, Type)</l>
<l>                endif</l>
<l>            endif</l>
<l>            write_dict (G_ParmDict, ParmSettingPath, 'file_type', 'json')</l>
<c></c>
<l>        endif</l>
<l>    else</l>
<l>        create_dict (ModelDict)</l>
<l>        create_dict (NodesDict)</l>
<l>Init_Leaf (NodesDict, Leaf, Competence, Type, Limit, DefaultValue, Value)</l>
<l>        set_dict_tuple (ModelDict, Nodes, NodesDict)</l>
<l>        set_dict_tuple (G_ParmDict, Model, ModelDict)</l>
<l>        tuple_type (DefaultValue, ValueType)</l>
<l>        if (ValueType=8)</l>
<l>EnQueueLog_COPY_1 ('错误', 'LoadParam函数错误', Model+'&gt;'+Nodes+'&gt;'+Leaf, Type)</l>
<l>        endif</l>
<l>        if (Type='int' or Type='int[]' or Type='int_enum')</l>
<l>            if (ValueType!=1)</l>
<l>EnQueueLog_COPY_1 ('错误', 'LoadParam函数错误', Model+'&gt;'+Nodes+'&gt;'+Leaf, Type)</l>
<l>            endif</l>
<l>        elseif (Type='float' or Type='float[]' or Type='float_enum')</l>
<l>            if (ValueType!=2)</l>
<l>EnQueueLog_COPY_1 ('错误', 'LoadParam函数错误', Model+'&gt;'+Nodes+'&gt;'+Leaf, Type)</l>
<l>            endif</l>
<l>        elseif (Type='string' or Type='string[]' or Type='string_enum')</l>
<l>            if (ValueType!=4)</l>
<l>EnQueueLog_COPY_1 ('错误', 'LoadParam函数错误', Model+'&gt;'+Nodes+'&gt;'+Leaf, Type)</l>
<l>            endif</l>
<l>        endif</l>
<l>        write_dict (G_ParmDict, ParmSettingPath, 'file_type', 'json')</l>
<c></c>
<c></c>
<l>    endif</l>
<l>catch (Exception)</l>
<l>endtry</l>
<l>unlock_mutex (G_ParmDictMutex)</l>
<c></c>
<l>if (Type='string[]')</l>
<l>    try</l>
<l>        get_dict_param (Value, 'keys', [], GenParamValue)</l>
<l>        get_dict_tuple (Value, GenParamValue, Tuple)</l>
<l>        tuple_split (Tuple, '[",]', Value)</l>
<l>    catch (Exception)</l>
<l>        tuple_split (Value, '[",]', Value)</l>
<c></c>
<l>    endtry</l>
<c></c>
<l>elseif (Type='int[]' or Type='float[]')</l>
<l>    try</l>
<c></c>
<l>        try</l>
<l>            tuple_split (Tuple, '[",]', Tuple)</l>
<l>        catch (Exception)</l>
<l>        endtry</l>
<l>        tuple_number (Tuple, Value)</l>
<l>    catch (Exception)</l>
<l>        try</l>
<l>            tuple_number (Tuple, Value)</l>
<l>        catch (Exception)</l>
<l>        endtry</l>
<c></c>
<l>    endtry</l>
<l>endif</l>
<l>return ()</l>
</body>
<docu id="LoadParam_COPY_1">
<abstract lang="zh_CN">我们的参数采取jason的形式去存储，拥有三个层级[Model][node][KeyName],这三样对应到软件界面即“标签页”、“树状图”、“lable”
其KeyName对应的属性有
["Value"]          输出的参数值
["type"]           该参数的数据类型
["Competence"]     管理权限
["Limit"]           参数限制
以下是一个示例表现其用法我们以[初始化设置][网口设置][IP地址]
{
"初始化设置" : 
{
"网口设置" : 
{
      "IP地址": {
        "Competence": 2,
        "Value": "192.168.1.1",
        "type": "string",
        "Limit": [-2500000,25000000]
 
      },
      "端口号": {
        "Competence": 1,
        "Value": 2000,
        "type": "int",
        "Limit": [ -2500000, 25000000 ]
      }
}
}
}
 </abstract>
<parameters>
<parameter id="Competence">
<default_type>integer</default_type>
<default_value>1</default_value>
<description lang="zh_CN">管理权限，这个权限有三级，”操作员”（1），”工程师”（2），”厂商”（3）,拥有不同密码，密码在config文件下明码修改，输入对应密码后显示对应参数。</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<sem_type>integer</sem_type>
<type_list>
<item>integer</item>
</type_list>
<value_list>
<item>1</item>
<item>2</item>
<item>3</item>
</value_list>
<value_max>3</value_max>
<value_min>1</value_min>
</parameter>
<parameter id="DefaultValue">
<description lang="zh_CN">没有参数时输出的默认值</description>
<sem_type>any</sem_type>
</parameter>
<parameter id="Leaf">
<default_type>string</default_type>
<description lang="zh_CN">标签， 参数的名称</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
</parameter>
<parameter id="Limit">
<description lang="zh_CN">参数限制，在参数类型是数字类时做大小限制的限制，是一个数组，第 一位最小值，第二位是最大值，参数类型是枚举时该参数为被枚举所有元 素</description>
<multivalue>optional</multivalue>
<sem_type>any</sem_type>
</parameter>
<parameter id="Model">
<default_type>string</default_type>
<description lang="zh_CN">一级目录，显示为标签页</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
</parameter>
<parameter id="Nodes">
<default_type>string</default_type>
<description lang="zh_CN">二级目录，显示为树状图</description>
<mixed_type>false</mixed_type>
<multivalue>optional</multivalue>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
</parameter>
<parameter id="Type">
<default_type>string</default_type>
<default_value>int</default_value>
<description lang="zh_CN">当你解析好界面上的参数["Value"]以什么数据类型 输出，详见附录“数据类型与控件对应”</description>
<mixed_type>false</mixed_type>
<multivalue>false</multivalue>
<sem_type>string</sem_type>
<type_list>
<item>string</item>
</type_list>
<value_list>
<item>'int'</item>
<item>'float'</item>
<item>'bool'</item>
<item>'int[]'</item>
<item>'float[]'</item>
<item>'string'</item>
<item>'string[]'</item>
<item>'string_enum'</item>
<item>'int_enum'</item>
<item>'float_enum'</item>
<item>'path'</item>
</value_list>
</parameter>
<parameter id="Value">
<description lang="zh_CN">输出的参数值</description>
<sem_type>any</sem_type>
</parameter>
</parameters>
</docu>
</procedure>
<procedure name="Read_JT">
<interface>
<oc>
<par name="JD" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>Read_Modbus ('int', 46, 1, Tuple1)</l>
<l>Read_Modbus ('int', 3500, 1, Tuple2)</l>
<l>JD := Tuple1+Tuple2</l>
<l>return ()</l>
</body>
<docu id="Read_JT">
<parameters>
<parameter id="JD"/>
</parameters>
</docu>
</procedure>
<procedure name="LJ_BJ">
<interface>
<io>
<par name="EmptyObjectT" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="start" base_type="ctrl" dimension="0"/>
<par name="InciseLeth" base_type="ctrl" dimension="0"/>
<par name="t" base_type="ctrl" dimension="0"/>
<par name="ID" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="LJ_Tuple" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>try</l>
<l>LJ_Juge (EmptyObjectT, start, InciseLeth, LJ_Tuple)</l>
<c></c>
<l>catch (Exception)</l>
<l>endtry</l>
<l>if (LJ_Tuple==-1)</l>
<l>    try</l>
<l>        write_object (EmptyObjectT, 'D:/孪晶/'+ID+'_'+t)</l>
<l>    catch (Exception)</l>
<l>    endtry</l>
<l>else</l>
<l>EnQueueLog ('Log', '检测到孪晶！！！！！！', 'ID', '')</l>
<l>    try</l>
<l>        write_object (EmptyObjectT, 'D:/孪晶过检/'+ID+'_'+t)</l>
<l>    catch (Exception)</l>
<l>    endtry</l>
<l>endif</l>
<c></c>
<c></c>
<c></c>
<l>return ()</l>
</body>
<docu id="LJ_BJ">
<parameters>
<parameter id="EmptyObjectT"/>
<parameter id="ID"/>
<parameter id="InciseLeth"/>
<parameter id="LJ_Tuple"/>
<parameter id="start"/>
<parameter id="t"/>
</parameters>
</docu>
</procedure>
<procedure name="WAIT_FW">
<interface>
<oc>
<par name="JT" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>while (1)</l>
<l>Read_JT (JT)</l>
<l>    wait_seconds (1)</l>
<l>    if (JT=0)</l>
<l>        break</l>
<l>    endif</l>
<l>endwhile</l>
<l>return ()</l>
</body>
<docu id="WAIT_FW">
<parameters>
<parameter id="JT"/>
</parameters>
</docu>
</procedure>
<procedure name="Find_LINE_OF_crystal_Tail">
<interface>
<oo>
<par name="CrystalWiresObject" base_type="iconic" dimension="0"/>
</oo>
<ic>
<par name="pos" base_type="ctrl" dimension="0"/>
<par name="Diameter_Tuple" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="JT" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>global tuple QuitTaskFlag</l>
<l>global tuple G_ParmDict</l>
<c></c>
<c>* ****顶升***********************************************************</c>
<c></c>
<l>modbus_write_registerFloat ()</l>
<l>EnQueueLog ('Log', '设置运动速度', 1002, 1000)</l>
<l>modbus_write_registerFloat ()</l>
<l>EnQueueLog_COPY_1 ('Log', '设置运动位置到尾部找晶线', 126, pos)</l>
<l>modbus_write_bit (0, 126, 1)</l>
<l>EnQueueLog_COPY_1 ('Log', '开始直线运动', 126, 1)</l>
<l>modbus_write_bit (0, 175, 1)</l>
<c></c>
<l>while (QuitTaskFlag=0)</l>
<l>Read_Modbus ('bool', 126, 1, Tuple1)</l>
<l>Read_JT_COPY_1 (JT)</l>
<l>    if (JT=2)</l>
<l>        return ()</l>
<l>    endif</l>
<l>    if (Tuple1=0)</l>
<l>EnQueueLog_COPY_1 ('Log', '直线运动完成', 126, Tuple1)</l>
<l>        break</l>
<l>    endif</l>
<l>endwhile</l>
<l>* wait_seconds (5)</l>
<l>modbus_write_bit (0, 1002, 0)</l>
<l>EnQueueLog_COPY_1 ('Log', '滚轮旋转要改成触摸屏上显示的那种“手动模式”', 1002, 0)</l>
<l>wait_seconds (0.2)</l>
<l>LoadParams_COPY_1 (G_ParmDict, ['PLC参数','滚轮旋转','反转212|正转213'], 0, 212, 3, 'int_enum', [212,213], Value)</l>
<l>modbus_write_bit (0, 177, 1)</l>
<l>modbus_write_bit (0, 178, 1)</l>
<l>modbus_write_bit (0, Value, 1)</l>
<l>EnQueueLog_COPY_1 ('Log', '滚轮旋转', Value, 1)</l>
<l>wait_seconds (0.2)</l>
<c>* *********面诊相机找晶线**************</c>
<l>gen_empty_obj (CrystalWiresObject)</l>
<c></c>
<l>try</l>
<l>Hik_start_framegrabber ()</l>
<l>EnQueueLog_COPY_1 ('Log', '找晶线相机开启采集', ' ', ' ')</l>
<l>Find_CrystalWires (CrystalWiresObject, CrystalWiresObject, 'N', Diameter_Tuple, JT)</l>
<l>LoadParams_COPY_1 (G_ParmDict, ['PLC参数','滚轮旋转','反转212|正转213'], 0, 212, 3, 'int_enum', [212,213], Value)</l>
<l>    modbus_write_bit (0, Value, 0)</l>
<l>EnQueueLog_COPY_1 ('Log', '找晶线完成滚轮停止', 212, 0)</l>
<l>Hik_stop_framegrabber ()</l>
<l>EnQueueLog_COPY_1 ('Log', '找晶线相机关闭采集', ' ', ' ')</l>
<l>    modbus_write_bit (0, 1002, 1)</l>
<l>EnQueueLog_COPY_1 ('Log', '恢复触摸屏上显示的那种“自动模式”', 1002, 1)</l>
<c></c>
<l>modbus_write_registerFloat ()</l>
<l>EnQueueLog ('Log', '设置运动速度', 1002, 1000)</l>
<l>modbus_write_registerFloat ()</l>
<l>EnQueueLog_COPY_1 ('Log', '找到晶线往尾部移动200mm', 126, pos)</l>
<l>    modbus_write_bit (0, 126, 1)</l>
<c></c>
<c></c>
<c></c>
<l>    if (JT=2)</l>
<l>        return ()</l>
<l>    endif</l>
<l>catch (Exception)</l>
<l>endtry</l>
<c>* ******************************************</c>
<l>return ()</l>
</body>
<docu id="Find_LINE_OF_crystal_Tail">
<parameters>
<parameter id="CrystalWiresObject"/>
<parameter id="Diameter_Tuple"/>
<parameter id="JT"/>
<parameter id="pos"/>
</parameters>
</docu>
</procedure>
<procedure name="LJAread_Measure">
<interface>
<io>
<par name="ObjectSelected" base_type="iconic" dimension="0"/>
</io>
<oo>
<par name="RegionTrans" base_type="iconic" dimension="0"/>
</oo>
</interface>
<body>
<l>mean_image (ObjectSelected, ImageMean, 30, 9)</l>
<l>dyn_threshold (ObjectSelected, ImageMean, RegionDynThresh, 5, 'light')</l>
<l>opening_circle (RegionDynThresh, RegionOpening1, 3)</l>
<l>closing_rectangle1 (RegionOpening1, RegionClosing1, 100, 250)</l>
<l>region_features (RegionClosing1, 'area', Value)</l>
<l>if (Value&lt;600000)</l>
<l>    return ()</l>
<l>endif</l>
<l>opening_rectangle1 (RegionClosing1, RegionOpening2, 20, 300)</l>
<l>connection (RegionOpening2, ConnectedRegions)</l>
<l>dilation_rectangle1 (ConnectedRegions, RegionDilation, 1, 4000)</l>
<c></c>
<l>union1 (RegionDilation, RegionUnion)</l>
<l>connection (RegionUnion, RegionUnion)</l>
<c></c>
<l>shape_trans (RegionUnion, RegionUnion, 'rectangle1')</l>
<l>union1 (RegionUnion, RegionUnion1)</l>
<c></c>
<l>shape_trans (RegionUnion1, RegionTrans1, 'rectangle1')</l>
<l>difference (RegionTrans1, RegionUnion, RegionDifference)</l>
<l>erosion_rectangle1 (RegionDifference, RegionErosion, 50, 1)</l>
<c></c>
<l>reduce_domain (ObjectSelected, RegionErosion, ImageReduced)</l>
<l>* crop_domain (ImageReduced, ImagePart)</l>
<c></c>
<l>mean_image (ImageReduced, ImageMean, 30, 9)</l>
<l>dyn_threshold (ImageReduced, ImageMean, RegionDynThresh, 5, 'light')</l>
<l>opening_circle (RegionDynThresh, RegionOpening1, 3)</l>
<l>closing_rectangle1 (RegionOpening1, RegionClosing1, 20, 50)</l>
<l>opening_rectangle1 (RegionClosing1, RegionOpening2, 120, 10)</l>
<l>shape_trans (RegionOpening2, RegionTrans, 'convex')</l>
<l>return ()</l>
</body>
<docu id="LJAread_Measure">
<parameters>
<parameter id="ObjectSelected"/>
<parameter id="RegionTrans"/>
</parameters>
</docu>
</procedure>
<procedure name="Read_JT_COPY_1">
<interface>
<oc>
<par name="JD" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>Read_Modbus ('int', 46, 1, Tuple1)</l>
<l>Read_Modbus ('int', 3500, 1, Tuple2)</l>
<l>JD := Tuple1+Tuple2</l>
<l>return ()</l>
</body>
<docu id="Read_JT_COPY_1">
<parameters>
<parameter id="JD"/>
</parameters>
</docu>
</procedure>
<procedure name="PC_Call">
<interface>
<ic>
<par name="ID_Tuple" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>try</l>
<c></c>
<c></c>
<l>    for Index := 0 to 22 by 1</l>
<l>        modbus_write_register (0, 2170+Index, ID_Tuple[Index])</l>
<l>    endfor</l>
<c></c>
<l>catch (Exception)</l>
<l>endtry</l>
<c></c>
<l>modbus_write_register (0, 2200, 1)</l>
<l>return ()</l>
</body>
<docu id="PC_Call">
<parameters>
<parameter id="ID_Tuple"/>
</parameters>
</docu>
</procedure>
<procedure name="Find_Tail_JX">
<interface>
<oo>
<par name="CrystalWiresObject" base_type="iconic" dimension="0"/>
</oo>
<ic>
<par name="endIncise" base_type="ctrl" dimension="0"/>
<par name="Diameter_Tuple" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="JT" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>while (1)</l>
<c></c>
<l>WAIT_FW (JT)</l>
<l>Find_LINE_OF_crystal_Tail (CrystalWiresObject, endIncise, Diameter_Tuple, JT)</l>
<l>    if (JT=2)</l>
<l>        continue</l>
<l>    else</l>
<l>        break</l>
<l>    endif</l>
<c></c>
<l>endwhile</l>
<l>return ()</l>
</body>
<docu id="Find_Tail_JX">
<parameters>
<parameter id="CrystalWiresObject"/>
<parameter id="Diameter_Tuple"/>
<parameter id="JT"/>
<parameter id="endIncise"/>
</parameters>
</docu>
</procedure>
<procedure name="BV_GrapImage">
<interface>
<oo>
<par name="ObjectData" base_type="iconic" dimension="0"/>
<par name="Image" base_type="iconic" dimension="0"/>
</oo>
<ic>
<par name="QueueHandle" base_type="ctrl" dimension="0"/>
<par name="Handle" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>* gen_image_const (Image, 'uint2', 1024, 13000)</l>
<l>* while(1)</l>
<l>* try</l>
<l>* wait_seconds (1)</l>
<c></c>
<l>* dequeue_message (QueueHandle, 'timeout', 1, MessageHandle)</l>
<l>* get_message_obj (ObjectData, MessageHandle, 'image')</l>
<c></c>
<l>* EnQueueLog ('log', 'info', '采集到图片', 1)</l>
<c></c>
<l>* break</l>
<c></c>
<l>* catch (Exception)</l>
<l>* endtry</l>
<c></c>
<l>* endwhile</l>
<l>p:=0</l>
<l>SER:=0</l>
<c></c>
<l>gen_image_const (Image, 'uint2', 1024, 15000)</l>
<l>while(1)</l>
<l>    count_seconds (Seconds)</l>
<l>    try</l>
<l>        if (SER&gt;0)</l>
<l>            T:=Seconds-SRE</l>
<l>            if (T&gt;30)</l>
<l>               break </l>
<l>            endif</l>
<l>        endif</l>
<l>        wait_seconds (1)</l>
<l>        for Index := 0 to 148 by 1</l>
<l>            dequeue_message (QueueHandle, 'timeout', 1, MessageHandle)</l>
<l>            count_seconds (SRE)</l>
<l>            if (Index=0)</l>
<l>                wait_seconds (5)</l>
<l>            endif</l>
<l>            get_message_obj (ObjectData, MessageHandle, 'image')</l>
<l>            p:=p+1</l>
<l>            gen_rectangle1 (Rectangle, 0 ,0, 99, 1023)</l>
<l>            get_region_points (Rectangle, Rows, Columns)</l>
<l>            get_grayval (ObjectData, Rows, Columns, Grayval)</l>
<l>            Rows:=Rows+Index*100</l>
<l>            set_grayval (Image, Rows, Columns, Grayval)</l>
<l>            wait_seconds (0.001)</l>
<l>            if (p&gt;149)</l>
<l>                break</l>
<l>            endif</l>
<l>*             concat_obj (EmptyObject, ObjectData, EmptyObject)</l>
<l>        endfor</l>
<l>        while (1)</l>
<l>            try</l>
<c>                </c>
<c>         </c>
<l>            dequeue_message (QueueHandle, 'timeout', 1, MessageHandle)</l>
<l>               catch (Exception)</l>
<l>                   break</l>
<l>            endtry</l>
<l>        endwhile</l>
<l>        EnQueueLog ('log', 'info', '采集到图片', 1)</l>
<c>        </c>
<c>        </c>
<c>        </c>
<l>        break</l>
<c>        </c>
<l>    catch (Exception)</l>
<l>    endtry</l>
<c>    </c>
<l>endwhile</l>
<l>return ()</l>
</body>
<docu id="BV_GrapImage">
<parameters>
<parameter id="Handle"/>
<parameter id="Image"/>
<parameter id="ObjectData"/>
<parameter id="QueueHandle"/>
</parameters>
</docu>
</procedure>
<procedure name="ROI">
<interface>
<io>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<oo>
<par name="ImageReduced1" base_type="iconic" dimension="0"/>
</oo>
</interface>
<body>
<l>rotate_image (Image, ImageRotate, 90, 'constant')</l>
<l>* ImageRotate1:=ImageRotate</l>
<c></c>
<l>* decompose3 (ImageRotate, Image1, Image2, ImageRotate)</l>
<c>*判断棒子是否超出光源*</c>
<l>threshold (ImageRotate, Region2, 3500, 4096)</l>
<l>closing_rectangle1 (Region2, RegionClosing, 4800, 1)</l>
<l>shape_trans (RegionClosing, RegionTrans, 'inner_rectangle1')</l>
<l>reduce_domain (ImageRotate, RegionTrans, ImageReduced)</l>
<l>sobel_amp (ImageReduced, EdgeAmplitude, 'sum_abs', 3)</l>
<l>threshold (EdgeAmplitude, Region3, 2500, 4096)</l>
<l>gen_rectangle1 (ROI_0, -98.5141, -78.6564, 400, 5124.81)</l>
<l>difference (Region3, ROI_0, Region3)</l>
<l>opening_rectangle1 (Region3, RegionOpening1, 100, 1)</l>
<l>region_features (RegionOpening1, 'area', Value4)</l>
<c></c>
<c></c>
<l>if (Value4&gt;10)</l>
<l>    dilation_rectangle1 (RegionOpening1, RegionOpening1, 11, 1)</l>
<l>region_features (RegionOpening1, 'column1', Value)</l>
<l>region_features (RegionOpening1, 'column2', Value1)</l>
<l>region_features (RegionOpening1, 'row2', Value2)</l>
<l>gen_rectangle1 (Rectangle, 1, Value, Value2, Value1)</l>
<c></c>
<l> threshold (ImageRotate, Region4, 0, 4096)</l>
<l>   difference (Region4, Rectangle, RegionDifference1)</l>
<l>   paint_region (RegionDifference1, ImageRotate, ImageReduced1, 0, 'fill')</l>
<l>else</l>
<l>    threshold (ImageRotate, Region, 0, 50)</l>
<l>    gen_rectangle1 (ROI_0, 686.748, -103.149, 1252.91, 5044.33)</l>
<l>intersection (Region, ROI_0, RegionIntersection)</l>
<l>    closing_rectangle1 (RegionIntersection, RegionClosing1, 4800, 1)</l>
<l>    shape_trans (RegionClosing1, RegionTrans1, 'inner_rectangle1')</l>
<l>    erosion_rectangle1 (RegionTrans1, RegionErosion, 1, 1)</l>
<l>    reduce_domain (ImageRotate, RegionErosion, ImageReduced1)</l>
<c></c>
<c>    </c>
<l>   mean_image (ImageReduced1, ImageMean2, 1, 30)</l>
<l>   dyn_threshold (ImageReduced1, ImageMean2, RegionDynThresh2, 5, 'light')</l>
<l>   region_features (RegionDynThresh2, 'column1', Value3)</l>
<l>   region_features (RegionDynThresh2, 'column2', Value5)</l>
<l>   region_features (RegionDynThresh2, 'row2', Value6)</l>
<c>   </c>
<l>   gen_rectangle1 (Rectangle1, 1, Value3, Value6, Value5)</l>
<c>   </c>
<l>   dilation_rectangle1 (Rectangle1, RegionOpening1, 11, 1)</l>
<l>   threshold (ImageRotate, Region4, 0, 4096)</l>
<l>   difference (Region4, RegionOpening1, RegionDifference1)</l>
<l>   paint_region (RegionDifference1, ImageRotate, ImageReduced1, 0, 'fill')</l>
<l>    *reduce_domain (ImageRotate, Rectangle1, ImageReduced3)</l>
<l>endif</l>
<l>gen_rectangle1 (ROI_0, -131.536, 290.439, 33.9008, 4859.5)</l>
<l>paint_region (ROI_0, ImageReduced1, ImageReduced1, 0, 'fill')</l>
<c></c>
<l>return ()</l>
</body>
<docu id="ROI">
<parameters>
<parameter id="Image"/>
<parameter id="ImageReduced1"/>
</parameters>
</docu>
</procedure>
<procedure name="Code_Tcp">
<interface>
<oc>
<par name="ReaderIP" base_type="ctrl" dimension="0"/>
<par name="SocketHandle" base_type="ctrl" dimension="0"/>
<par name="CQueueHandle" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<c></c>
<l>global tuple QuitTaskFlag</l>
<l>ReaderIP    := '192.168.12.56' </l>
<l>ReaderPort  := 5000  </l>
<l>Timeout     := 2 </l>
<l>open_socket_connect (ReaderIP, ReaderPort, ['protocol','timeout'], ['TCP',Timeout], SocketHandle)</l>
<l>set_socket_param (SocketHandle, 'timeout', 1)</l>
<l>create_message_queue (CQueueHandle)</l>
<l>set_message_queue_param (CQueueHandle, 'max_message_num', 10)</l>
<l> send_data (SocketHandle, 'z', 'start',[ReaderIP,5000])</l>
<l>par_start&lt;ThreadID&gt; : Rec_Code (SocketHandle, CQueueHandle, ReaderIP)</l>
<l>return ()</l>
</body>
<docu id="Code_Tcp">
<parameters>
<parameter id="CQueueHandle"/>
<parameter id="ReaderIP"/>
<parameter id="SocketHandle"/>
</parameters>
</docu>
</procedure>
<procedure name="Rec_Code">
<interface>
<ic>
<par name="SocketHandle" base_type="ctrl" dimension="0"/>
<par name="CQueueHandle" base_type="ctrl" dimension="0"/>
<par name="ReaderIP" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>global tuple QuitTaskFlag</l>
<l>while (QuitTaskFlag=0)</l>
<l>    try</l>
<l>        wait_seconds (1)</l>
<l>         receive_data (SocketHandle, 'z', CHAR, From) </l>
<l>        create_message (MessageHandle)</l>
<l>        EnQueueLog ('log', 'info', '晶编', CHAR)</l>
<c></c>
<l>        set_message_tuple (MessageHandle, '晶编', CHAR)</l>
<l>        enqueue_message (CQueueHandle, MessageHandle, [], [])</l>
<l>        clear_message (MessageHandle)</l>
<l>        wait_seconds (5)</l>
<l>         send_data (SocketHandle, 'z', 'start',[ReaderIP,5000])</l>
<l>          EnQueueLog ('log', 'info', '扫码指令', '发送')</l>
<l>    catch (Exception)</l>
<l>    endtry</l>
<l>endwhile</l>
<l>return ()</l>
</body>
<docu id="Rec_Code">
<parameters>
<parameter id="CQueueHandle"/>
<parameter id="ReaderIP"/>
<parameter id="SocketHandle"/>
</parameters>
</docu>
</procedure>
<procedure name="Init_Xkk">
<interface>
<oc>
<par name="DictHandle" base_type="ctrl" dimension="0"/>
<par name="DictHandle1" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>create_dict (DictHandle)</l>
<l>	set_dict_tuple(DictHandle, '工程路径', './json/Model_seg.m')//工程路径</l>
<l>	set_dict_tuple(DictHandle, '批处理数', 1)//填1就行了</l>
<l>	set_dict_tuple(DictHandle, '使用设备', 0)//0代表cpu，1代表gpu</l>
<l>	set_dict_tuple(DictHandle, '推理设备索引', 0)//0代表用cpu，1代表用核显</l>
<l>	set_dict_tuple(DictHandle, '工程序号',0)//</l>
<l>DnnInfer_Init (DictHandle)</l>
<c></c>
<l>create_dict (DictHandle1)</l>
<l>set_dict_tuple(DictHandle1, '工程路径', './json/Model_cls.m')//工程路径</l>
<l>set_dict_tuple(DictHandle1, '批处理数', 1)//填1就行了</l>
<l>set_dict_tuple(DictHandle1, '使用设备', 0)//0代表cpu，1代表gpu</l>
<l>set_dict_tuple(DictHandle1, '推理设备索引', 0)//0代表用cpu，1代表用核显</l>
<l>set_dict_tuple(DictHandle1, '工程序号',1)//</l>
<l>DnnInfer_Init (DictHandle1)</l>
<c></c>
<c></c>
<c></c>
<l>return ()</l>
</body>
<docu id="Init_Xkk">
<parameters>
<parameter id="DictHandle"/>
<parameter id="DictHandle1"/>
</parameters>
</docu>
</procedure>
<procedure name="ht">
<interface>
<io>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<oo>
<par name="Image1" base_type="iconic" dimension="0"/>
<par name="Image2" base_type="iconic" dimension="0"/>
</oo>
</interface>
<body>
<l>        get_image_size (Image, Width, Height)</l>
<l>       * decompose3 (Image, Image11, ImageZoomed, Image3)</l>
<l>gen_image_const (Image1, 'uint2', Width, Height/2)</l>
<l>gen_image_const (Image2, 'uint2', Width, Height/2)</l>
<c></c>
<l>for Index := 0 to Height-1 by 2</l>
<l>    gen_rectangle1 (Rectangle1, Index, 0, Index, 1023)</l>
<l>    gen_rectangle1 (Rectangle2, Index+1, 0, Index+1, 1023)</l>
<l>    get_region_points (Rectangle1, Rows1, Columns1)</l>
<l>    get_region_points (Rectangle2, Rows2, Columns2)</l>
<l>    get_grayval (Image, Rows2, Columns2, Grayval2)</l>
<l>    get_grayval (Image, Rows1, Columns1, Grayval1)</l>
<l>    set_grayval (Image2, Rows2/2, Columns2, Grayval2)</l>
<l>    set_grayval (Image1, Rows1/2, Columns1, Grayval1)</l>
<l>endfor</l>
<l>return ()</l>
</body>
<docu id="ht">
<parameters>
<parameter id="Image"/>
<parameter id="Image1"/>
<parameter id="Image2"/>
</parameters>
</docu>
</procedure>
<procedure name="Median_Tuple">
<interface>
<io>
<par name="RegionErosion" base_type="iconic" dimension="0"/>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<oc>
<par name="Max" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<c></c>
<l>threshold (Image, Regions, 0, 12000)</l>
<l>intersection (RegionErosion, Regions, RegionErosion)</l>
<c></c>
<l>select_shape (RegionErosion, SelectedRegions, 'height', 'and', 99, 99999)</l>
<l>select_shape (SelectedRegions, SelectedRegions, 'area', 'and', 380*100, 99999)</l>
<c></c>
<c></c>
<c></c>
<l>gray_features (SelectedRegions, Image, 'mean', Value1)</l>
<l>* tuple_median (Value1, Median)</l>
<l>* Values := []</l>
<l>* for Index := 0 to |Value1| - 1 by 1</l>
<l>*     if (Value1[Index]&gt;Median)</l>
<l>*         Values := [Values,Value1[Index]]</l>
<c></c>
<l>*     endif</l>
<l>* endfor</l>
<c></c>
<l>* tuple_median (Values, Median)</l>
<l>* Valuess := []</l>
<l>* for Index := 0 to |Values| - 1 by 1</l>
<l>*     if (Values[Index]&lt;Median)</l>
<l>*         Valuess := [Valuess,Values[Index]]</l>
<c></c>
<l>*     endif</l>
<l>* endfor</l>
<c></c>
<l>try</l>
<l>    tuple_max (Value1, Max)</l>
<c></c>
<l>catch (Exception)</l>
<l>    Max := 12000</l>
<l>endtry</l>
<c></c>
<c></c>
<c></c>
<c></c>
<c></c>
<l>return ()</l>
</body>
<docu id="Median_Tuple">
<parameters>
<parameter id="Image"/>
<parameter id="Max"/>
<parameter id="RegionErosion"/>
</parameters>
</docu>
</procedure>
<procedure name="Init_Yolo">
<interface>
<oc>
<par name="DictHandle" base_type="ctrl" dimension="0"/>
<par name="ModelHandle" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<c></c>
<l>ModelPath := './best.xml'</l>
<l>Device := 'CPU'</l>
<c>* 加载模型 (字符串值用set_dict_tuple, 对象用set_dict_object)</c>
<l>create_dict (DictHandle)</l>
<l>set_dict_tuple (DictHandle, '工程路径', ModelPath)</l>
<l>set_dict_tuple (DictHandle, '使用设备', Device)</l>
<l>set_dict_tuple (DictHandle, '宽',640)</l>
<l>set_dict_tuple (DictHandle,'高',640)</l>
<l>set_dict_tuple (DictHandle, 'ConfThreshold', 0.15)</l>
<l>set_dict_tuple (DictHandle, 'MaskThreshold', 0.15)</l>
<l>OpenvinoLoadModel (DictHandle, ModelHandle)</l>
<l>      EnQueueLog ('log', 'info', '加载yolo', 1)</l>
<l>return ()</l>
</body>
<docu id="Init_Yolo">
<parameters>
<parameter id="DictHandle"/>
<parameter id="ModelHandle"/>
</parameters>
</docu>
</procedure>
<procedure name="Roi">
<interface>
<io>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<oo>
<par name="RegionDifference1" base_type="iconic" dimension="0"/>
</oo>
</interface>
<body>
<c>     </c>
<c>    </c>
<l>    rotate_image (Image, ImageRotate, 0, 'constant')</l>
<l>* ImageRotate1:=ImageRotate</l>
<c></c>
<l>* decompose3 (ImageRotate, Image1, Image2, ImageRotate)</l>
<c>*判断棒子是否超出光源*</c>
<l>threshold (ImageRotate, Region2, 230, 255)</l>
<l>closing_rectangle1 (Region2, RegionClosing, 4800, 1)</l>
<l>shape_trans (RegionClosing, RegionTrans, 'inner_rectangle1')</l>
<l>reduce_domain (ImageRotate, RegionTrans, ImageReduced)</l>
<l>sobel_amp (ImageReduced, EdgeAmplitude, 'sum_abs', 3)</l>
<l>threshold (EdgeAmplitude, Region3, 50, 255)</l>
<l>gen_rectangle1 (ROI_0, 0, 0, 600, 5120)</l>
<l>difference (Region3, ROI_0, Region3)</l>
<l>opening_rectangle1 (Region3, RegionOpening1, 20, 1)</l>
<l>try</l>
<c>    </c>
<c></c>
<l>connection (RegionOpening1, ConnectedRegions)</l>
<l>region_features (ConnectedRegions, 'outer_radius', Value4)</l>
<l>tuple_max (Value4, Value4)</l>
<l>catch (Exception)</l>
<l>    Value4:=0</l>
<l>endtry</l>
<c></c>
<c></c>
<l>if (Value4&gt;500)</l>
<l>    dilation_rectangle1 (RegionOpening1, RegionOpening1, 1, 1)</l>
<l>region_features (RegionOpening1, 'row2', Value)</l>
<l>region_features (RegionOpening1, 'column1', Value1)</l>
<l>region_features (RegionOpening1, 'column2', Value2)</l>
<l>gen_rectangle1 (Rectangle, 80, Value1, 1023, Value2)</l>
<c></c>
<l> threshold (ImageRotate, Region4, 0, 255)</l>
<l>   difference (Region4, Rectangle, RegionDifference1)</l>
<l>    *erosion_rectangle1 (RegionDifference1, RegionDifference1, 30, 1)</l>
<l> dilation_rectangle1 (RegionDifference1, RegionDifference1, 20, 1)</l>
<l>   paint_region (RegionDifference1, ImageRotate, ImageReduced1, 0, 'fill')</l>
<l>else</l>
<l>    threshold (ImageRotate, Region, 0, 50)</l>
<l>    gen_rectangle1 (ROI_0, 500, 0, 1200, 5000)</l>
<l>intersection (Region, ROI_0, RegionIntersection)</l>
<l>    closing_rectangle1 (RegionIntersection, RegionClosing1, 4800, 1)</l>
<l>    shape_trans (RegionClosing1, RegionTrans1, 'inner_rectangle1')</l>
<l>    erosion_rectangle1 (RegionTrans1, RegionErosion, 1, 1)</l>
<l>    reduce_domain (ImageRotate, RegionErosion, ImageReduced1)</l>
<c></c>
<c>    </c>
<l>   mean_image (ImageReduced1, ImageMean2, 1, 30)</l>
<l>   dyn_threshold (ImageReduced1, ImageMean2, RegionDynThresh2, 5, 'light')</l>
<l>   closing_rectangle1 (RegionDynThresh2, RegionClosing2, 2, 2)</l>
<l>   opening_rectangle1 (RegionClosing2, RegionOpening, 200, 1)</l>
<l>region_features (RegionOpening, 'row2', Value)</l>
<l>region_features (RegionOpening, 'column1', Value1)</l>
<l>region_features (RegionOpening, 'column2', Value2)</l>
<l>gen_rectangle1 (Rectangle, 80, Value1, 1023, Value2)</l>
<c>   </c>
<l>   dilation_rectangle1 (Rectangle, RegionOpening1, 1, 1)</l>
<l>   threshold (ImageRotate, Region4, 0, 4096)</l>
<l>   difference (Region4, RegionOpening1, RegionDifference1)</l>
<l>   *erosion_rectangle1 (RegionDifference1, RegionDifference1, 30, 1)</l>
<l>    dilation_rectangle1 (RegionDifference1, RegionDifference1, 20, 1)</l>
<l>   paint_region (RegionDifference1, ImageRotate, ImageReduced1, 0, 'fill')</l>
<l>    *reduce_domain (ImageRotate, Rectangle1, ImageReduced3)</l>
<l>endif</l>
<c></c>
<l>* gen_rectangle1 (ROI_0, -131.536, 290.439, 33.9008, 4859.5)</l>
<l>* paint_region (ROI_0, ImageReduced1, ImageReduced1, 0, 'fill')</l>
<c></c>
<c></c>
<c></c>
<l>return ()</l>
</body>
<docu id="Roi">
<parameters>
<parameter id="Image"/>
<parameter id="RegionDifference1"/>
</parameters>
</docu>
</procedure>
<procedure name="DEImage">
<interface>
<io>
<par name="Image" base_type="iconic" dimension="0"/>
</io>
<oo>
<par name="Image1" base_type="iconic" dimension="0"/>
<par name="Image2" base_type="iconic" dimension="0"/>
<par name="Image3" base_type="iconic" dimension="0"/>
</oo>
</interface>
<body>
<l>gen_image_const (Image1, 'uint2', 1024, 5000)</l>
<l>gen_image_const (Image2, 'uint2', 1024, 5000)</l>
<l>gen_image_const (Image3, 'uint2', 1024, 5000)</l>
<l>for Index := 0 to 14997 by 3</l>
<l>    gen_rectangle1 (Rectangle, Index, 0, Index, 1023)</l>
<l>    get_region_points (Rectangle, Rows, Columns)</l>
<l>    get_grayval (Image, Rows, Columns, Grayval)</l>
<l>    set_grayval (Image1, Rows/3, Columns, Grayval)</l>
<c></c>
<l>    gen_rectangle1 (Rectangle, Index+1, 0, Index+1, 1023)</l>
<l>    get_region_points (Rectangle, Rows, Columns)</l>
<l>    get_grayval (Image, Rows, Columns, Grayval)</l>
<l>    set_grayval (Image2, Rows/3, Columns, Grayval)</l>
<c></c>
<c></c>
<l>    gen_rectangle1 (Rectangle, Index+2, 0, Index+2, 1023)</l>
<l>    get_region_points (Rectangle, Rows, Columns)</l>
<l>    get_grayval (Image, Rows, Columns, Grayval)</l>
<l>    set_grayval (Image3, Rows/3, Columns, Grayval)</l>
<l>endfor</l>
<l>return ()</l>
</body>
<docu id="DEImage">
<parameters>
<parameter id="Image"/>
<parameter id="Image1"/>
<parameter id="Image2"/>
<parameter id="Image3"/>
</parameters>
</docu>
</procedure>
</hdevelop>
