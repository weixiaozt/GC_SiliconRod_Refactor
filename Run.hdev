<item>'white'</item>
<item>'red'</item>
<item>'green'</item>
<item>'blue'</item>
<item>'cyan'</item>
<item>'magenta'</item>
<item>'yellow'</item>
<item>'dim gray'</item>
<item>'gray'</item>
<item>'light gray'</item>
<item>'medium slate blue'</item>
<item>'coral'</item>
<item>'slate blue'</item>
<item>'spring green'</item>
<item>'orange red'</item>
<item>'orange'</item>
<item>'dark olive green'</item>
<item>'pink'</item>
<item>'cadet blue'</item>
</values>
</parameter>
<parameter id="object">
<description lang="zh_CN">输入要显示的内容</description>
