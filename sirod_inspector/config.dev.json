        "height": 100,
        "acquisition_mode": "MultiFrame",
        "acquisition_frame_count": 150,
        "multiframe_first_wait_s": 5.0,
        "exposure_us": null,
        "trigger_source": "Software",
        "grab_timeout_ms": 10000,
        "loop_interval_s": 2.0
    },
    "database": {
