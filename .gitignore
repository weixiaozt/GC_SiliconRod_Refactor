__pycache__/
*.pyc
tests/outputs/
tests/_diag*.txt
*.log
logs/
.claude/
.venv/
源码备份/
# 现场图源（很大，不入库）
source_image/*.zip
source_image/*.zip.*
source_image/*.tif
source_image/ImageRaw/

# 部署 zip — 33-376MB 二进制，按需重新打包（python scripts/deploy/build_zip.py）
SiliconRod_v2_deploy.zip
# 解压 zip 出来的临时部署目录
SiliconRod_v2_deploy/

# 从开发机直接打的 EasyLabel CPU 运行时（~124MB），按需重新打包
EasyLabel_DL_runtime.zip

# 第三方 SDK 安装包（268MB exe + 76MB demo，超 GitHub 100MB 限制）
# 部署机需要单独装：参考 DEPLOY.md
第三方AI推理SDK/

# 大体积测试输出（推理 crop 等）
tests/outputs/

# config.json 本地备份（用户 dev/yancheng 切换时手动备份）
sirod_inspector/config.json.v1.bak
sirod_inspector/config.*.bak
sirod_inspector/config.json.before-*

# 项目根目录的 config.json（现场实际部署使用，含敏感数据，不入库）
/config.json

# sirod_inspector/config.json — 现装现场真实生产配置（含 DB 密码），改完直接拷现场，不入库
# 模板见 config.example.json / config.v2.example.json
sirod_inspector/config.json

# 部署前 hash 校验生成的临时清单
code_hash.txt

# 测试图（414 张 .bmp，太大）
test_image/*.bmp

# 运行时数据 — 不同部署机各自生成
sirod_inspector/shift_stats.json

# 启动器 exe（由 scripts/deploy/build_launcher.bat 按需打包，~7MB 二进制不入库）
scripts/deploy/SiRodLauncher.exe
# PyInstaller 打包中间产物
.build_launcher/
build/
dist/
*.spec

# IDE 工程配置（PyCharm / IntelliJ）
.idea/

# ── 软件授权锁（license_guard）★ 私钥/授权/编译产物绝不入库 ★ ──
# 私钥：泄露 = 所有授权可被伪造（用 *.pem 兜底，当前项目无其它 pem）
*.pem
private_key.pem
# 授权文件：每台机器签发，按机部署，不入库
license.dat
/license.dat
sirod_inspector/license.dat
# 编译产物：含内嵌真实公钥，keygen 后按需编译部署（源码 .py 留占位公钥进库）
sirod_inspector/core/license_guard*.pyd
